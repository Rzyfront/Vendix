# Enforcement of subscription gate. Default (unset) = enforce 402/403.
# Set to `false` ONLY to fall back to log-only observation (e.g. incident bypass).
# DEPRECATED alias kept for backwards-compat: AI_GATE_ENFORCE
STORE_GATE_ENFORCE=true

# G12 — Event-driven subscription state engine.
# When `true`, a successful payment in grace_soft/grace_hard/suspended/blocked
# immediately promotes the subscription back to `active` via the webhook
# listener. When `false` (default), the daily 03:00 UTC cron is the source of
# truth and the listener only emits `STATE_ENGINE_OBSERVATION` log markers.
# The first-payment path (pending_payment → active) is always enforced and
# is NOT controlled by this flag.
# Rollout: false (deploy + observe 7d) → true in staging (3d) → true in prod.
SUBSCRIPTION_EVENT_DRIVEN_STATE=false

# Wompi recurrent charges rollout flag.
# - false (default): log-only mode. PMs sin payment_source_id usan flujo legacy
#   inline token con warning WOMPI_LEGACY_TOKEN_USED.
# - true: enforce mode. PMs sin payment_source_id son rechazados con
#   PAYMENT_METHOD_NOT_MIGRATED, forzando re-tokenización del usuario.
# Activar solo después de validar uplift de approval rate >= +5% sobre baseline
# durante 14 días en cohort 100% (ver plan de rollout).
WOMPI_RECURRENT_ENFORCE=false

# Social Sales Hub / Meta WhatsApp
# Prefer managing these values from Super Admin platform_settings
# key: social_sales:meta_whatsapp. Env values are a deployment fallback.
META_APP_ID=
META_APP_SECRET=
META_WHATSAPP_CONFIG_ID=
META_WHATSAPP_VERIFY_TOKEN=
META_GRAPH_VERSION=v23.0
META_WHATSAPP_APP_REVIEW_STATUS=pending
META_WHATSAPP_ALLOW_DEV_SIGNUP=false
SOCIAL_CHANNEL_ENCRYPTION_KEY=

# Auth — refresh token storage.
# Secreto HMAC-SHA256 con el que se hashean los refresh tokens antes de
# guardarlos (lookup directo por hash, sin bcrypt). OBLIGATORIO en producción:
# si no se define, el backend cae a un fallback dev-only documentado y NO apto
# para prod. Al cambiar este valor se invalidan todas las sesiones activas
# (los hashes previos dejan de coincidir) → re-login único. No afecta contraseñas.
REFRESH_TOKEN_HMAC_SECRET=
