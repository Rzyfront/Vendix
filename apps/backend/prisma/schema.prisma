// ──── Wallet Interna ────────────────────────

enum wallet_transaction_type_enum {
  credit
  debit
  hold
  release
}

enum wallet_transaction_state_enum {
  pending
  completed
  failed
  reversed
}

enum customer_queue_status_enum {
  waiting
  selected
  consumed
  expired
  cancelled
}

enum invoice_data_request_status_enum {
  pending
  submitted
  processing
  completed
  expired
  failed
}

model wallets {
  id              Int      @id @default(autoincrement())
  store_id        Int
  organization_id Int
  customer_id     Int
  balance         Decimal  @default(0.00) @db.Decimal(12, 2)
  held_balance    Decimal  @default(0.00) @db.Decimal(12, 2)
