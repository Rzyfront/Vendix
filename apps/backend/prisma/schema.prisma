  currency            String?                 @db.VarChar(10)
  num_installments    Int
  notes               String?                 @db.Text
  internal_notes      String?                 @db.Text
  started_at          DateTime?               @db.Timestamp(6)
  completed_at        DateTime?               @db.Timestamp(6)
  cancelled_at        DateTime?               @db.Timestamp(6)
  cancellation_reason String?                 @db.Text
  created_by_user_id  Int?
  created_at          DateTime?               @default(now()) @db.Timestamp(6)
  updated_at          DateTime?               @default(now()) @db.Timestamp(6)

  stores               stores                 @relation(fields: [store_id], references: [id], onUpdate: NoAction)
  customer             users                  @relation("layaway_customer", fields: [customer_id], references: [id], onDelete: Restrict)
  created_by           users?                 @relation("layaway_created_by", fields: [created_by_user_id], references: [id], onDelete: Restrict)
  layaway_items        layaway_items[]
  layaway_installments layaway_installments[]
  layaway_payments     layaway_payments[]

  @@unique([store_id, plan_number])
  @@index([store_id, state])
  @@index([customer_id])
}

model layaway_items {
  id                 Int       @id @default(autoincrement())
  layaway_plan_id    Int
  product_id         Int
  product_variant_id Int?
  product_name       String    @db.VarChar(255)
  variant_name       String?   @db.VarChar(255)
  sku                String?   @db.VarChar(100)
  quantity           Int
  unit_price         Decimal   @db.Decimal(12, 2)
  discount_amount    Decimal   @default(0.00) @db.Decimal(12, 2)
  tax_amount         Decimal   @default(0.00) @db.Decimal(12, 2)
  subtotal           Decimal   @db.Decimal(12, 2)
  location_id        Int?
  created_at         DateTime? @default(now()) @db.Timestamp(6)
  updated_at         DateTime? @default(now()) @db.Timestamp(6)

  layaway_plan        layaway_plans        @relation(fields: [layaway_plan_id], references: [id], onDelete: Cascade)
  products            products             @relation(fields: [product_id], references: [id], onDelete: Restrict)
  product_variants    product_variants?    @relation(fields: [product_variant_id], references: [id], onDelete: Restrict)
  inventory_locations inventory_locations? @relation(fields: [location_id], references: [id], onDelete: Restrict)

  @@index([layaway_plan_id])
  @@index([product_id])
}

model layaway_installments {
  id                 Int                            @id @default(autoincrement())
  layaway_plan_id    Int
  installment_number Int
  amount             Decimal                        @db.Decimal(12, 2)
  due_date           DateTime                       @db.Timestamp(6)
  state              layaway_installment_state_enum @default(pending)
  paid_at            DateTime?                      @db.Timestamp(6)
  reminder_sent_at   DateTime?                      @db.Timestamp(6)
  created_at         DateTime?                      @default(now()) @db.Timestamp(6)
  updated_at         DateTime?                      @default(now()) @db.Timestamp(6)

  layaway_plan     layaway_plans      @relation(fields: [layaway_plan_id], references: [id], onDelete: Cascade)
  layaway_payments layaway_payments[]

  @@unique([layaway_plan_id, installment_number])
  @@index([layaway_plan_id])
  @@index([due_date, state])
}

model layaway_payments {
  id                      Int                 @id @default(autoincrement())
  layaway_plan_id         Int
  layaway_installment_id  Int?
  amount                  Decimal             @db.Decimal(12, 2)
  currency                String?             @db.VarChar(10)
  store_payment_method_id Int?
  transaction_id          String?             @unique @db.VarChar(255)
  state                   payments_state_enum @default(pending)
  paid_at                 DateTime?           @db.Timestamp(6)
  notes                   String?             @db.Text
  received_by_user_id     Int?
  created_at              DateTime?           @default(now()) @db.Timestamp(6)
  updated_at              DateTime?           @default(now()) @db.Timestamp(6)

  layaway_plan          layaway_plans          @relation(fields: [layaway_plan_id], references: [id], onDelete: Cascade)
  layaway_installment   layaway_installments?  @relation(fields: [layaway_installment_id], references: [id], onDelete: Restrict)
  store_payment_methods store_payment_methods? @relation(fields: [store_payment_method_id], references: [id], onDelete: Restrict)
  received_by           users?                 @relation("layaway_payment_received_by", fields: [received_by_user_id], references: [id], onDelete: Restrict)

  @@index([layaway_plan_id])
  @@index([layaway_installment_id])
}

