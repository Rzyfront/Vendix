model return_order_items {
  id                 Int                 @id @default(autoincrement())
  return_order_id    Int
  product_id         Int
  product_variant_id Int?
  quantity           Int
  condition          item_condition_enum @default(good)
  created_at         DateTime?           @default(now()) @db.Timestamp(6)
  products           products            @relation(fields: [product_id], references: [id], onDelete: Cascade)
  product_variants   product_variants?   @relation(fields: [product_variant_id], references: [id], onDelete: Cascade)
  return_orders      return_orders       @relation(fields: [return_order_id], references: [id], onDelete: Cascade)

  @@index([return_order_id, product_id])
}

// ===== SHIPPING & LOGISTICS DOMAIN =====

model shipping_zones {
  id             Int              @id @default(autoincrement())
  store_id       Int?
  name           String           @db.VarChar(100)
  display_name   String?          @db.VarChar(100)
  countries      String[] // Array of ISO country codes
  regions        String[] // Array of region/state codes
  cities         String[] // Specific cities if needed
  zip_codes      String[] // Zip code patterns
  is_active      Boolean          @default(true)
  is_system      Boolean          @default(false)
  created_at     DateTime?        @default(now()) @db.Timestamp(6)
  updated_at     DateTime?        @default(now()) @db.Timestamp(6)

  // Tracking de copia del sistema (One-Click Magic)
  copied_from_system_zone_id Int?                           // ID de zona del sistema de donde se copió
  source_type                zone_source_type_enum?         // 'system_copy' | 'custom'

  // Relaciones
  store              stores?               @relation(fields: [store_id], references: [id], onDelete: Cascade)
  shipping_rates     shipping_rates[]
  copied_from_zone   shipping_zones?       @relation("ZoneCopies", fields: [copied_from_system_zone_id], references: [id], onDelete: SetNull)
  copied_zones       shipping_zones[]      @relation("ZoneCopies")
  system_updates     system_zone_updates[]

  @@index([store_id])
  @@index([is_system])
  @@index([copied_from_system_zone_id])
  @@index([source_type])
}

model shipping_methods {
  id             Int                       @id @default(autoincrement())
  store_id       Int?
  name           String                    @db.VarChar(100)
  code           String?                   @db.VarChar(50)
  description    String?
  logo_url       String?
  type           shipping_method_type_enum @default(custom)
  provider_name  String?                   @db.VarChar(50) // e.g., "fedex", "uber"
  tracking_url   String?
  min_days       Int?
  max_days       Int?
  is_active      Boolean                   @default(true)
  is_system      Boolean                   @default(false)
  display_order  Int                       @default(0)
  custom_config  Json?
  min_order_amount Decimal?                @db.Decimal(12, 2)
  max_order_amount Decimal?                @db.Decimal(12, 2)
  copied_from_system_method_id Int?
  created_at     DateTime?                 @default(now()) @db.Timestamp(6)
  updated_at     DateTime?                 @default(now()) @db.Timestamp(6)

  store                  stores?                  @relation(fields: [store_id], references: [id], onDelete: Cascade)
  shipping_rates         shipping_rates[]
  orders                 orders[]
  copied_from_method     shipping_methods?        @relation("MethodCopies", fields: [copied_from_system_method_id], references: [id], onDelete: SetNull)
  copied_methods         shipping_methods[]       @relation("MethodCopies")

  @@index([store_id])
  @@index([is_system])
  @@index([copied_from_system_method_id])
}

model shipping_rates {
  id                      Int                     @id @default(autoincrement())
  shipping_zone_id        Int
  shipping_method_id      Int
  name                    String?                 @db.VarChar(100)
  type                    shipping_rate_type_enum @default(flat)
  base_cost               Decimal                 @default(0.00) @db.Decimal(12, 2)
  per_unit_cost           Decimal?                @default(0.00) @db.Decimal(12, 2) // Price per kg or per item
  min_val                 Decimal?                @db.Decimal(12, 2) // Min condition (weight/price)
  max_val                 Decimal?                @db.Decimal(12, 2) // Max condition (weight/price)
  free_shipping_threshold Decimal?                @db.Decimal(12, 2)
  is_active               Boolean                 @default(true)
  created_at              DateTime?               @default(now()) @db.Timestamp(6)
  updated_at              DateTime?               @default(now()) @db.Timestamp(6)

  // Tracking de copia del sistema
  copied_from_system_rate_id Int?                           // ID de tarifa del sistema de donde se copió
  source_type                zone_source_type_enum?         // 'system_copy' | 'custom'

  // Relaciones
  shipping_zone   shipping_zones   @relation(fields: [shipping_zone_id], references: [id], onDelete: Cascade)
  shipping_method shipping_methods @relation(fields: [shipping_method_id], references: [id], onDelete: Cascade)
  orders          orders[]

  @@index([shipping_zone_id])
  @@index([shipping_method_id])
  @@index([copied_from_system_rate_id])
}

// Tracking de cambios en zonas del sistema para notificar a tiendas
model system_zone_updates {
  id             Int            @id @default(autoincrement())
  system_zone_id Int
  change_type    String         @db.VarChar(50) // 'updated' | 'new_rate' | 'rate_updated' | 'deleted'
  description    String
  created_at     DateTime       @default(now()) @db.Timestamp(6)

  // Relación con la zona del sistema
  system_zone shipping_zones @relation(fields: [system_zone_id], references: [id], onDelete: Cascade)

  @@index([system_zone_id])
  @@index([created_at])
}

// ===== ECOMMERCE MODELS =====

model carts {
  id         Int       @id @default(autoincrement())
  store_id   Int
  user_id    Int
  currency   String?   @db.VarChar(10)
  subtotal   Decimal   @default(0.00) @db.Decimal(12, 2)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)

  cart_items cart_items[]
  store      stores       @relation(fields: [store_id], references: [id], onDelete: Cascade)
  user       users        @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([store_id, user_id])
  @@index([user_id])
}

model cart_items {
  id                 Int       @id @default(autoincrement())
  cart_id            Int
  product_id         Int
  product_variant_id Int?
  quantity           Int
  unit_price         Decimal   @db.Decimal(12, 2)
  created_at         DateTime? @default(now()) @db.Timestamp(6)

  cart            carts             @relation(fields: [cart_id], references: [id], onDelete: Cascade)
  product         products          @relation(fields: [product_id], references: [id], onDelete: Cascade)
  product_variant product_variants? @relation(fields: [product_variant_id], references: [id], onDelete: Cascade)

  @@unique([cart_id, product_id, product_variant_id])
  @@index([cart_id])
}

model wishlists {
  id         Int       @id @default(autoincrement())
  store_id   Int
  user_id    Int
  created_at DateTime? @default(now()) @db.Timestamp(6)

  wishlist_items wishlist_items[]
  store          stores           @relation(fields: [store_id], references: [id], onDelete: Cascade)
  user           users            @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([store_id, user_id])
  @@index([user_id])
}

model wishlist_items {
  id                 Int       @id @default(autoincrement())
  wishlist_id        Int
  product_id         Int
  product_variant_id Int?
  added_at           DateTime? @default(now()) @db.Timestamp(6)

  wishlist        wishlists         @relation(fields: [wishlist_id], references: [id], onDelete: Cascade)
  product         products          @relation(fields: [product_id], references: [id], onDelete: Cascade)
  product_variant product_variants? @relation(fields: [product_variant_id], references: [id], onDelete: Cascade)

  @@unique([wishlist_id, product_id, product_variant_id])
  @@index([wishlist_id])
}

// ===== DEFAULT TEMPLATES =====

model default_templates {
  id                 Int                       @id @default(autoincrement())
  template_name      String                    @unique @db.VarChar(255)
  configuration_type template_config_type_enum
  template_data      Json
  description        String?                   @db.Text
  is_active          Boolean                   @default(true)
  is_system          Boolean                   @default(false)
  created_at         DateTime?                 @default(now()) @db.Timestamp(6)
  updated_at         DateTime?                 @default(now()) @db.Timestamp(6)

  @@index([configuration_type])
  @@index([is_active])
  @@index([is_system])
}

// ===== PROMOTIONS =====

model promotions {
  id                  Int                    @id @default(autoincrement())
  store_id            Int
  name                String                 @db.VarChar(255)
  description         String?
  code                String?                @db.VarChar(50)
  type                promotion_type_enum
  value               Decimal                @db.Decimal(12, 2)
  scope               promotion_scope_enum   @default(order)
  min_purchase_amount Decimal?               @db.Decimal(12, 2)
  max_discount_amount Decimal?               @db.Decimal(12, 2)
  usage_limit         Int?
  usage_count         Int                    @default(0)
  per_customer_limit  Int?
  start_date          DateTime               @db.Timestamp(6)
  end_date            DateTime?              @db.Timestamp(6)
  state               promotion_state_enum   @default(draft)
  is_auto_apply       Boolean                @default(false)
  priority            Int                    @default(0)
  created_at          DateTime?              @default(now()) @db.Timestamp(6)
  updated_at          DateTime?              @default(now()) @db.Timestamp(6)

  stores              stores                 @relation(fields: [store_id], references: [id], onUpdate: NoAction)
  promotion_products  promotion_products[]
  promotion_categories promotion_categories[]
  order_promotions    order_promotions[]

  @@unique([store_id, code])
  @@index([store_id, state])
  @@index([store_id, start_date, end_date])
}

model promotion_products {
  id           Int        @id @default(autoincrement())
  promotion_id Int
  product_id   Int
  promotions   promotions @relation(fields: [promotion_id], references: [id], onDelete: Cascade)
  products     products   @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([promotion_id, product_id])
