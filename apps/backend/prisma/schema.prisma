  @@unique([organization_id, employee_code])
  @@unique([organization_id, document_type, document_number])
  @@index([organization_id, status])
  @@index([store_id])
}

model payroll_runs {
  id                  Int                        @id @default(autoincrement())
  organization_id     Int
  store_id            Int?
  payroll_number      String                     @db.VarChar(50)
  status              payroll_status_enum         @default(draft)
  frequency           payroll_frequency_enum
  period_start        DateTime                   @db.Timestamp(6)
  period_end          DateTime                   @db.Timestamp(6)
  payment_date        DateTime?                  @db.Timestamp(6)
  total_earnings      Decimal                    @default(0) @db.Decimal(12, 2)
  total_deductions    Decimal                    @default(0) @db.Decimal(12, 2)
  total_employer_costs Decimal                   @default(0) @db.Decimal(12, 2)
  total_net_pay       Decimal                    @default(0) @db.Decimal(12, 2)
  send_status         document_send_status_enum  @default(not_applicable)
  applied_rules       Json?
  provider_response   Json?
  cune                String?                    @db.VarChar(255)
  xml_document        String?
  sent_at             DateTime?                  @db.Timestamp(6)
  accounting_entry_id Int?
  approved_by_user_id Int?
  approved_at         DateTime?                  @db.Timestamp(6)
  created_by_user_id  Int?
  created_at          DateTime?                  @default(now()) @db.Timestamp(6)
  updated_at          DateTime?                  @default(now()) @db.Timestamp(6)

  organization     organizations       @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  store            stores?             @relation(fields: [store_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  accounting_entry accounting_entries? @relation(fields: [accounting_entry_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  approved_by_user users?              @relation("payroll_runs_approved_by", fields: [approved_by_user_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  created_by_user  users?              @relation("payroll_runs_created_by", fields: [created_by_user_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  payroll_items    payroll_items[]

  @@unique([organization_id, payroll_number])
  @@index([organization_id, status])
  @@index([store_id])
}

model payroll_items {
  id                  Int       @id @default(autoincrement())
  payroll_run_id      Int
  employee_id         Int
  base_salary         Decimal   @db.Decimal(12, 2)
  worked_days         Int
  earnings            Json?
  deductions          Json?
  employer_costs      Json?
  total_earnings      Decimal   @default(0) @db.Decimal(12, 2)
  total_deductions    Decimal   @default(0) @db.Decimal(12, 2)
  total_employer_costs Decimal  @default(0) @db.Decimal(12, 2)
  net_pay             Decimal   @default(0) @db.Decimal(12, 2)
  created_at          DateTime? @default(now()) @db.Timestamp(6)

  payroll_run payroll_runs @relation(fields: [payroll_run_id], references: [id], onDelete: Cascade)
  employee    employees    @relation(fields: [employee_id], references: [id], onDelete: Restrict, onUpdate: NoAction)

  @@index([payroll_run_id])
  @@index([employee_id])
}

// ===== DIAN ELECTRONIC INVOICING =====

enum dian_nit_type_enum {
  NIT
  CC
  CE
  TI
  PP
  NIT_EXTRANJERIA
}

model dian_configurations {
  id                             Int                          @id @default(autoincrement())
  organization_id                Int
  store_id                       Int
  name                           String                       @db.VarChar(100)
  nit                            String                       @db.VarChar(20)
  nit_type                       dian_nit_type_enum           @default(NIT)
  nit_dv                         String?                      @db.VarChar(1)
  is_default                     Boolean                      @default(false)
  software_id                    String                       @db.VarChar(100)
  software_pin_encrypted         String                       @db.Text
  certificate_s3_key             String?                      @db.Text
  certificate_password_encrypted String?                      @db.Text
  certificate_expiry             DateTime?                    @db.Timestamp(6)
  environment                    dian_environment_enum        @default(test)
  enablement_status              dian_enablement_status_enum  @default(not_started)
  test_set_id                    String?                      @db.VarChar(100)
  last_test_result               Json?
  created_at                     DateTime?                    @default(now()) @db.Timestamp(6)
  updated_at                     DateTime?                    @default(now()) @db.Timestamp(6)

