  is_active       Boolean  @default(true)
  created_at      DateTime @default(now()) @db.Timestamp(6)
  updated_at      DateTime @default(now()) @db.Timestamp(6)

  stores              stores                @relation("store_wallets", fields: [store_id], references: [id])
  organizations       organizations         @relation("org_wallets", fields: [organization_id], references: [id])
  customer            users                 @relation("wallet_owner", fields: [customer_id], references: [id])
