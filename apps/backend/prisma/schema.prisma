  change_notes       String?             @db.Text
  created_at         DateTime?           @default(now()) @db.Timestamp(6)
  ticket             support_tickets     @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  changed_by         users?              @relation("status_changed_by", fields: [changed_by_user_id], references: [id], onDelete: SetNull)

  @@index([ticket_id, created_at], name: "support_status_history_ticket_id_created_at_idx")
}

model support_notifications {
  id            Int             @id @default(autoincrement())
  ticket_id     Int
  user_id       Int?
  user_email    String?
  channel       String          @default("email")
  status        String          @default("pending")
  subject       String
  message       String          @db.Text
  template_name String?
  sent_at       DateTime?       @db.Timestamp(6)
  error_message String?         @db.Text
  retry_count   Int             @default(0)
  created_at    DateTime?       @default(now()) @db.Timestamp(6)
  ticket        support_tickets @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  user          users?          @relation("notification_user", fields: [user_id], references: [id], onDelete: SetNull)

  @@index([ticket_id], name: "support_notifications_ticket_id_idx")
  @@index([user_id, status], name: "support_notifications_user_id_status_idx")
  @@index([status], name: "support_notifications_status_idx")
}

