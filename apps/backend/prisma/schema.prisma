  change_notes        String?                 @db.Text
  created_at          DateTime?               @default(now()) @db.Timestamp(6)
  ticket              support_tickets         @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  changed_by          users?                  @relation("status_changed_by", fields: [changed_by_user_id], references: [id], onDelete: SetNull)

