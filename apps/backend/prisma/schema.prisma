generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model users {
  id                        Int                         @id @default(autoincrement())
  username                  String                      @unique @db.VarChar(50)
  email                     String                      @db.VarChar(255)
  password                  String
  state                     user_state_enum             @default(pending_verification)
  last_login                DateTime?                   @db.Timestamp(6)
  failed_login_attempts     Int                         @default(0)
  locked_until              DateTime?                   @db.Timestamp(6)
  email_verified            Boolean                     @default(false)
  two_factor_enabled        Boolean                     @default(false)
  two_factor_secret         String?
  created_at                DateTime?                   @default(now()) @db.Timestamp(6)
  updated_at                DateTime?                   @default(now()) @db.Timestamp(6)
  first_name                String                      @db.VarChar(100)
  last_name                 String                      @db.VarChar(100)
  avatar_url                String?                     @db.Text
  organization_id           Int
  phone                     String?                     @db.VarChar(50)
  document_number           String?                     @db.VarChar(50)
  document_type             String?                     @db.VarChar(50)
  main_store_id             Int?
  addresses                 addresses[]                 @relation("user_addresses")
  api_keys                  api_keys[]
  audit_logs                audit_logs[]
  email_verification_tokens email_verification_tokens[]
  inventory_adjustments1    inventory_adjustments[]     @relation("inventory_adjustments_approved_by")
  inventory_adjustments     inventory_adjustments[]     @relation("inventory_adjustments_created_by")
  expenses1                 expenses[]                  @relation("expenses_approved_by")
  expenses                  expenses[]                  @relation("expenses_created_by")
  inventory_movements       inventory_movements[]
  inventory_transactions    inventory_transactions[]
  password_reset_tokens     password_reset_tokens[]
  purchase_orders1          purchase_orders[]           @relation("purchase_orders_approved_by")
  purchase_orders           purchase_orders[]           @relation("purchase_orders_created_by")
  refresh_tokens            refresh_tokens[]
  refunds                   refunds[]
  reviews                   reviews[]
  sales_orders1             sales_orders[]              @relation("sales_orders_approved_by")
  sales_orders              sales_orders[]              @relation("sales_orders_created_by")
  stock_reservations        stock_reservations[]
  stock_transfers1          stock_transfers[]           @relation("stock_transfers_approved_by")
  stock_transfers           stock_transfers[]           @relation("stock_transfers_created_by")
  store_users               store_users[]
  user_roles                user_roles[]
  user_sessions             user_sessions[]
  user_settings             user_settings?
  carts                     carts[]
  wishlists                 wishlists[]
  orders                    orders[]
  main_store                stores?                     @relation("main_store", fields: [main_store_id], references: [id], onUpdate: NoAction)
  organizations             organizations               @relation(fields: [organization_id], references: [id], onUpdate: NoAction)
  document_acceptances      document_acceptances[]
  notification_subscriptions notification_subscriptions[]
  push_subscriptions         push_subscriptions[]
  created_tickets            support_tickets[]          @relation("ticket_creator")
  assigned_tickets           support_tickets[]          @relation("ticket_assigned")
  uploaded_attachments       support_attachments[]      @relation("attachment_uploaded_by")
  comments                   support_comments[]          @relation("comment_author")
  status_changes             support_status_history[]   @relation("status_changed_by")
  support_notifications      support_notifications[]    @relation("notification_user")
  help_articles_authored      help_articles[]            @relation("help_article_author")

  // Quotation relations
  quotations_as_customer    quotations[]          @relation("quotations_customer")
  quotations_created        quotations[]          @relation("quotations_created_by")

  // Coupons
  coupon_uses               coupon_uses[]

  // Cash Register
  cash_register_sessions_opened  cash_register_sessions[] @relation("cash_register_sessions_opened_by")
  cash_register_sessions_closed  cash_register_sessions[] @relation("cash_register_sessions_closed_by")
  cash_register_movements        cash_register_movements[]

  // Promotions
  order_promotions_customer order_promotions[] @relation("order_promotions_customer")

  // Invoicing, Accounting & Payroll relations
  invoices_created         invoices[]            @relation("invoices_created_by")
  invoices_as_customer     invoices[]            @relation("invoices_customer")
  fiscal_periods_closed    fiscal_periods[]      @relation("fiscal_periods_closed_by")
  accounting_entries_created accounting_entries[] @relation("accounting_entries_created_by")
  accounting_entries_posted  accounting_entries[] @relation("accounting_entries_posted_by")
  employees_link           employees[]           @relation("employees_user")
  payroll_runs_approved    payroll_runs[]        @relation("payroll_runs_approved_by")
  payroll_runs_created     payroll_runs[]        @relation("payroll_runs_created_by")

  // Purchase order improvement relations
  po_attachments_uploaded  purchase_order_attachments[] @relation("po_attachment_uploader")
  po_payments_created      purchase_order_payments[]    @relation("po_payment_creator")
  po_receptions_received   purchase_order_receptions[]  @relation("po_reception_receiver")

  // Campos de tracking de términos
  terms_accepted_version String?   @db.VarChar(20)
  terms_accepted_at      DateTime? @db.Timestamp(6)
  requires_terms_update  Boolean   @default(false)

  @@index([email_verified])
  @@index([state])
  @@index([document_number])
  @@index([requires_terms_update])
}

model user_settings {
  id         Int            @id @default(autoincrement())
  user_id    Int            @unique

  // NUEVO: app_type determina a qué app tiene acceso el usuario (override post-login)
  app_type   app_type_enum  @default(STORE_ADMIN)

  config     Json?          @default("{}")
  created_at DateTime?      @default(now()) @db.Timestamp(6)
  updated_at DateTime?      @default(now()) @db.Timestamp(6)
  user       users          @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([app_type])
}

/// Relación flexible entre usuarios y tiendas (clientes, staff, managers, etc)
model store_users {
  id        Int      @id @default(autoincrement())
  store_id  Int
  user_id   Int
  createdAt DateTime @default(now())
  store     stores   @relation(fields: [store_id], references: [id])
  user      users    @relation(fields: [user_id], references: [id])

  @@unique([store_id, user_id])
}

model roles {
  id               Int                @id @default(autoincrement())
  name             String             @unique @db.VarChar(50)
  description      String?
  is_system_role   Boolean            @default(false)
  organization_id  Int?
  created_at       DateTime?          @default(now()) @db.Timestamp(6)
  updated_at       DateTime?          @default(now()) @db.Timestamp(6)
  role_permissions role_permissions[]
  user_roles       user_roles[]
  organizations    organizations?     @relation(fields: [organization_id], references: [id], onUpdate: NoAction)

  @@index([organization_id])
}

model permissions {
  id                   Int                    @id @default(autoincrement())
  name                 String                 @unique @db.VarChar(100)
  description          String?
  path                 String                 @db.VarChar(255)
  method               http_method_enum
  status               permission_status_enum @default(active)
  is_system_permission Boolean                @default(false)
  created_at           DateTime?              @default(now()) @db.Timestamp(6)
  updated_at           DateTime?              @default(now()) @db.Timestamp(6)
  role_permissions     role_permissions[]

  @@unique([path, method])
}

model user_roles {
  id      Int    @id @default(autoincrement())
  user_id Int?
  role_id Int?
  roles   roles? @relation(fields: [role_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  users   users? @relation(fields: [user_id], references: [id], onDelete: Restrict, onUpdate: NoAction)

  @@unique([user_id, role_id])
}

model role_permissions {
  id            Int         @id @default(autoincrement())
  role_id       Int
  permission_id Int
  granted       Boolean     @default(true)
  created_at    DateTime?   @default(now()) @db.Timestamp(6)
  permissions   permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  roles         roles       @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([role_id, permission_id])
}

model refresh_tokens {
  id                 Int       @id @default(autoincrement())
  user_id            Int?
  token              String
  device_info        String?
  expires_at         DateTime  @db.Timestamp(6)
  created_at         DateTime? @default(now()) @db.Timestamp(6)
  device_fingerprint String?   @db.VarChar(255)
  ip_address         String?   @db.VarChar(45)
  last_used          DateTime? @db.Timestamp(6)
  revoked            Boolean   @default(false)
  revoked_at         DateTime? @db.Timestamp(6)
  revoked_reason     String?   @db.VarChar(255)
  updated_at         DateTime? @default(now()) @db.Timestamp(6)
  user_agent         String?
  users              users?    @relation(fields: [user_id], references: [id], onDelete: Restrict, onUpdate: NoAction)

  @@index([user_id, revoked])
  @@index([expires_at])
  @@index([revoked])
  @@index([ip_address])
  @@index([last_used])
}

model user_sessions {
  id            Int       @id @default(autoincrement())
  user_id       Int
  session_id    String    @unique
  ip_address    String?   @db.VarChar(45)
  user_agent    String?
  device_info   String?
  location      String?   @db.VarChar(100)
  is_active     Boolean   @default(true)
  last_activity DateTime? @db.Timestamp(6)
  expires_at    DateTime  @db.Timestamp(6)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  users         users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model login_attempts {
  id             Int       @id @default(autoincrement())
  email          String    @db.VarChar(255)
  ip_address     String?   @db.VarChar(45)
  user_agent     String?
  success        Boolean
  failure_reason String?   @db.VarChar(100)
  attempted_at   DateTime? @default(now()) @db.Timestamp(6)
  store_id       Int?
  stores         stores?   @relation(fields: [store_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
}

model password_reset_tokens {
  id         Int       @id @default(autoincrement())
  user_id    Int
  token      String    @unique
  expires_at DateTime  @db.Timestamp(6)
  used       Boolean   @default(false)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model email_verification_tokens {
  id         Int       @id @default(autoincrement())
  user_id    Int
  token      String    @unique
  expires_at DateTime  @db.Timestamp(6)
  verified   Boolean   @default(false)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model audit_logs {
  id              Int            @id @default(autoincrement())
  user_id         Int?
  action          String         @db.VarChar(100)
  resource        String         @db.VarChar(100)
  resource_id     Int?
  old_values      Json?
  new_values      Json?
  ip_address      String?        @db.VarChar(45)
  user_agent      String?
  created_at      DateTime?      @default(now()) @db.Timestamp(6)
  organization_id Int?
  store_id        Int?
  organizations   organizations? @relation(fields: [organization_id], references: [id], onUpdate: NoAction)
  stores          stores?        @relation(fields: [store_id], references: [id], onUpdate: NoAction)
  users           users?         @relation(fields: [user_id], references: [id], onUpdate: NoAction)
}

model organizations {
  id                            Int                            @id @default(autoincrement())
  name                          String                         @db.VarChar(255)
  slug                          String                         @unique @db.VarChar(255)
  legal_name                    String?                        @db.VarChar(255)
  tax_id                        String?                        @unique @db.VarChar(50)
  email                         String                         @db.VarChar(255)
  phone                         String?                        @db.VarChar(50)
  website                       String?                        @db.VarChar(255)
  description                   String?
  logo_url                      String?                        @db.Text
  state                         organization_state_enum        @default(draft)
  account_type                  organization_account_type_enum @default(SINGLE_STORE)
  created_at                    DateTime?                      @default(now()) @db.Timestamp(6)
  updated_at                    DateTime?                      @default(now()) @db.Timestamp(6)
  onboarding                    Boolean                        @default(false)
  addresses                     addresses[]
  audit_logs                    audit_logs[]
  domain_settings               domain_settings[]
  inventory_adjustments         inventory_adjustments[]
  inventory_locations           inventory_locations[]
  inventory_movements           inventory_movements[]
  organization_settings         organization_settings?
  organization_payment_policies organization_payment_policies?
  purchase_orders               purchase_orders[]
  return_orders                 return_orders[]
  sales_orders                  sales_orders[]
  stock_reservations            stock_reservations[]
  stock_transfers               stock_transfers[]
  stores                        stores[]
  suppliers                     suppliers[]
  users                         users[]
  roles                         roles[]
  expenses                      expenses[]
  expense_categories            expense_categories[]
  support_tickets               support_tickets[]
  invoices                      invoices[]
  invoice_resolutions           invoice_resolutions[]
  chart_of_accounts             chart_of_accounts[]
  fiscal_periods                fiscal_periods[]
  accounting_entries            accounting_entries[]
  employees                     employees[]
  payroll_runs                  payroll_runs[]
  dian_configurations           dian_configurations[]
  accounting_account_mappings   accounting_account_mappings[]
  inventory_cost_layers         inventory_cost_layers[]

  @@index([onboarding])
  @@index([account_type])
}

model organization_settings {
  id              Int           @id @default(autoincrement())
  organization_id Int           @unique
  settings        Json?         // Renombrado de "config" a "settings" para consistencia con store_settings
  created_at      DateTime?     @default(now()) @db.Timestamp(6)
  updated_at      DateTime?     @default(now()) @db.Timestamp(6)
  organization    organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)
}

model organization_payment_policies {
  id              Int @id @default(autoincrement())
  organization_id Int @unique

  // Configuración de métodos permitidos
  allowed_methods String[] // IDs de system_payment_methods permitidos para la organización

  // Configuración base para nuevas tiendas
  default_config Json? // Configuración base que heredan las tiendas

  // Políticas organizacionales
  enforce_policies      Boolean @default(false) // Si se aplican las políticas a todas las tiendas
  allow_store_overrides Boolean @default(true) // Si las tiendas pueden modificar configuraciones

  // Configuraciones globales
  min_order_amount Decimal? @db.Decimal(12, 2) // Monto mínimo global para pedidos
  max_order_amount Decimal? @db.Decimal(12, 2) // Monto máximo global para pedidos

  // Auditoría
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)

  // Relaciones
  organization organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([organization_id])
}

model stores {
  id                    Int                     @id @default(autoincrement())
  name                  String                  @db.VarChar(255)
  slug                  String                  @db.VarChar(255)
  created_at            DateTime?               @default(now()) @db.Timestamp(6)
  updated_at            DateTime?               @default(now()) @db.Timestamp(6)
  is_active             Boolean                 @default(true)
  logo_url              String?                 @db.Text
  manager_user_id       Int?
  organization_id       Int
  store_code            String?                 @unique @db.VarChar(20)
  store_type            store_type_enum         @default(physical)
  timezone              String?                 @db.VarChar(50)
  onboarding            Boolean                 @default(false)
  addresses             addresses[]
  audit_logs            audit_logs[]
  categories            categories[]
  domain_settings       domain_settings[]
  inventory_locations   inventory_locations[]
  login_attempts        login_attempts[]
  orders                orders[]
  products              products[]
  store_payment_methods store_payment_methods[]
  store_settings        store_settings?
  store_users           store_users[]
  organizations         organizations           @relation(fields: [organization_id], references: [id])
  tax_categories        tax_categories[]
  tax_rates             tax_rates[]
  carts                 carts[]
  wishlists             wishlists[]
  main_store_users      users[]                 @relation("main_store")
  shipping_zones         shipping_zones[]
  shipping_methods       shipping_methods[]
  expenses               expenses[]
  notifications          notifications[]
  notification_subscriptions notification_subscriptions[]
  push_subscriptions         push_subscriptions[]
  support_tickets            support_tickets[]
  invoices                   invoices[]
  invoice_resolutions        invoice_resolutions[]
  accounting_entries         accounting_entries[]
  employees                  employees[]
  payroll_runs               payroll_runs[]
  dian_configurations          dian_configurations[]
  accounting_account_mappings  accounting_account_mappings[]
  quotations                   quotations[]
  promotions                     promotions[]
  coupons                        coupons[]

  // Cash Register
  cash_registers                   cash_registers[]
  cash_register_sessions           cash_register_sessions[] @relation("cash_register_sessions_store")
  cash_register_movements          cash_register_movements[]

  @@unique([organization_id, slug])
  @@index([onboarding])
}

model store_settings {
  id         Int       @id @default(autoincrement())
  store_id   Int       @unique
  settings   Json?
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  stores     stores    @relation(fields: [store_id], references: [id], onUpdate: NoAction)
}

model domain_settings {
  id                 Int                   @id @default(autoincrement())
  hostname           String                @unique @db.VarChar(255)
  organization_id    Int?
  store_id           Int?

  // NUEVO: app_type es la única fuente de verdad para el tipo de aplicación
  app_type           app_type_enum         @default(VENDIX_LANDING)

  // config ahora es opcional - solo metadata de routing/security si se necesita
  config             Json?                 @default("{}")

  created_at         DateTime?             @default(now()) @db.Timestamp(6)
  updated_at         DateTime?             @default(now()) @db.Timestamp(6)
  domain_type        domain_type_enum      @default(organization)
  is_primary         Boolean               @default(false)
  last_error         String?               @db.VarChar(255)
  last_verified_at   DateTime?             @db.Timestamp(6)
  ssl_status         ssl_status_enum       @default(none)
  status             domain_status_enum    @default(pending_dns)
  verification_token String?               @unique @db.VarChar(100)
  ownership          domain_ownership_enum @default(vendix_subdomain)
  organization       organizations?        @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  store              stores?               @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@index([hostname])
  @@index([organization_id])
  @@index([store_id])
  @@index([status])
  @@index([domain_type])
  @@index([ownership])
  @@index([app_type])
}

model addresses {
  id                                           Int                   @id @default(autoincrement())
  store_id                                     Int?
  address_line1                                String
  address_line2                                String?
  city                                         String                @db.VarChar(100)
  state_province                               String?               @db.VarChar(100)
  country_code                                 String                @db.VarChar(3)
  postal_code                                  String?               @db.VarChar(20)
  phone_number                                 String?               @db.VarChar(50)
  type                                         address_type_enum     @default(shipping)
  is_primary                                   Boolean               @default(false)
  latitude                                     Decimal?              @db.Decimal(10, 8)
  longitude                                    Decimal?              @db.Decimal(11, 8)
  organization_id                              Int?
  user_id                                      Int?
  organizations                                organizations?        @relation(fields: [organization_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  stores                                       stores?               @relation(fields: [store_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  users                                        users?                @relation("user_addresses", fields: [user_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  inventory_locations                          inventory_locations[] @relation("inventory_location_addresses")
  suppliers                                    suppliers[]           @relation("supplier_addresses")
  orders_orders_billing_address_idToaddresses  orders[]              @relation("orders_billing_address_idToaddresses")
  orders_orders_shipping_address_idToaddresses orders[]              @relation("orders_shipping_address_idToaddresses")
  sales_orders                                 sales_orders[]        @relation("sales_orders_shipping_address")
}

model brands {
  id          Int              @id @default(autoincrement())
  name        String           @unique @db.VarChar(100)
  description String?
  logo_url    String?
  created_at  DateTime?        @default(now()) @db.Timestamp(6)
  updated_at  DateTime?        @default(now()) @db.Timestamp(6)
  state       brand_state_enum @default(active)
  products    products[]
}

model categories {
  id                 Int                  @id @default(autoincrement())
  store_id           Int?
  name               String               @db.VarChar(255)
  slug               String               @db.VarChar(255)
  description        String?
  image_url          String?
  state              category_state_enum  @default(active)
  stores             stores?              @relation(fields: [store_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  product_categories   product_categories[]
  promotion_categories promotion_categories[]
  coupon_categories    coupon_categories[]

  @@unique([store_id, slug])
}

model currencies {
  code           String                       @id @db.VarChar(3)
  name           String                       @unique @db.VarChar(255)
  symbol         String                       @db.VarChar(10)
  decimal_places Int                          @default(2) @db.SmallInt
  position       currency_position_enum       @default(after)
  state          currency_state_enum          @default(active)
}

model inventory_transactions {
  id                 Int                             @id @default(autoincrement())
  product_id         Int
  product_variant_id Int?
  user_id            Int?
  order_item_id      Int?
  type               inventory_transaction_type_enum
  notes              String?
  transaction_date   DateTime?                       @default(now()) @db.Timestamp(6)
  quantity_change    Int
  created_at         DateTime?                       @default(now()) @db.Timestamp(6)
  order_items        order_items?                    @relation(fields: [order_item_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  products           products                        @relation(fields: [product_id], references: [id], onUpdate: NoAction)
  product_variants   product_variants?               @relation(fields: [product_variant_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  users              users?                          @relation(fields: [user_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
}

model order_item_taxes {
  id            Int         @id @default(autoincrement())
  order_item_id Int
  tax_rate_id   Int?
  tax_name      String      @db.VarChar(100)
  tax_rate      Decimal     @db.Decimal(6, 5)
  tax_amount    Decimal     @db.Decimal(12, 2)
  is_compound   Boolean?
  created_at    DateTime?   @default(now()) @db.Timestamp(6)
  order_items   order_items @relation(fields: [order_item_id], references: [id], onUpdate: NoAction)
  tax_rates     tax_rates?  @relation(fields: [tax_rate_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
}

model order_items {
  id                     Int                      @id @default(autoincrement())
  order_id               Int
  product_id             Int?
  product_variant_id     Int?
  product_name           String                   @db.VarChar(255)
  variant_sku            String?                  @db.VarChar(100)
  variant_attributes     String?
  quantity               Int
  unit_price             Decimal                  @db.Decimal(12, 2)
  total_price            Decimal                  @db.Decimal(12, 2)
  tax_rate               Decimal?                 @db.Decimal(6, 5)
  tax_amount_item        Decimal?                 @db.Decimal(12, 2)
  cost_price             Decimal?                 @db.Decimal(12, 2)
  weight                 Decimal?                 @db.Decimal(10, 3)
  weight_unit            String?                  @db.VarChar(10)
  created_at             DateTime?                @default(now()) @db.Timestamp(6)
  updated_at             DateTime?                @default(now()) @db.Timestamp(6)
  inventory_transactions inventory_transactions[]
  order_item_taxes       order_item_taxes[]
  orders                 orders                   @relation(fields: [order_id], references: [id], onUpdate: NoAction)
  products               products?                @relation(fields: [product_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  product_variants       product_variants?        @relation(fields: [product_variant_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  refund_items           refund_items[]
}

model orders {
  id                                              Int                      @id @default(autoincrement())
  store_id                                        Int
  customer_id                                     Int?
  order_number                                    String                   @db.VarChar(50)
  shipping_address_id                             Int?
  billing_address_id                              Int?
  shipping_address_snapshot                       Json?
  billing_address_snapshot                        Json?
  currency                                        String?                  @db.VarChar(10)
  subtotal_amount                                 Decimal                  @default(0.00) @db.Decimal(12, 2)
  discount_amount                                 Decimal                  @default(0.00) @db.Decimal(12, 2)
  tax_amount                                      Decimal                  @default(0.00) @db.Decimal(12, 2)
  shipping_cost                                   Decimal                  @default(0.00) @db.Decimal(12, 2)
  grand_total                                     Decimal                  @default(0.00) @db.Decimal(12, 2)
  state                                           order_state_enum         @default(created)
  channel                                         order_channel_enum       @default(pos)
  delivery_type                                   order_delivery_type_enum @default(direct_delivery)
  shipping_method_id                              Int?
  shipping_rate_id                                Int?
  internal_notes                                  String?
  created_at                                      DateTime?                @default(now()) @db.Timestamp(6)
  updated_at                                      DateTime?                @default(now()) @db.Timestamp(6)
  coupon_id                                       Int?
  coupon_code                                     String?                  @db.VarChar(50)
  placed_at                                       DateTime?                @db.Timestamp(6)
  completed_at                                    DateTime?                @db.Timestamp(6)
  order_items                                     order_items[]
  addresses_orders_billing_address_idToaddresses  addresses?               @relation("orders_billing_address_idToaddresses", fields: [billing_address_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  addresses_orders_shipping_address_idToaddresses addresses?               @relation("orders_shipping_address_idToaddresses", fields: [shipping_address_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  stores                                          stores                   @relation(fields: [store_id], references: [id], onUpdate: NoAction)
  users                                           users?                   @relation(fields: [customer_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  payments                                        payments[]
  refunds                                         refunds[]
  shipping_method                                 shipping_methods?        @relation(fields: [shipping_method_id], references: [id], onDelete: SetNull)
  shipping_rate                                   shipping_rates?          @relation(fields: [shipping_rate_id], references: [id], onDelete: SetNull)
  invoices                                        invoices[]
  quotations                                      quotations[]
  order_promotions                                order_promotions[]
  coupon                                          coupons?                 @relation(fields: [coupon_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  coupon_uses                                     coupon_uses[]
  cash_register_movements                         cash_register_movements[]

  @@unique([store_id, order_number])
  @@index([store_id, order_number])
  @@index([store_id, channel])
}

model system_payment_methods {
  id                    Int                            @id @default(autoincrement())
  name                  String                         @unique @db.VarChar(100)
  display_name          String                         @db.VarChar(100)
  description           String?
  type                  payment_methods_type_enum
  provider              String                         @db.VarChar(100)
  logo_url              String?
  is_active             Boolean                        @default(true)
  requires_config       Boolean                        @default(false)
  config_schema         Json?
  default_config        Json?
  supported_currencies  String[]
  min_amount            Decimal?                       @db.Decimal(12, 2)
  max_amount            Decimal?                       @db.Decimal(12, 2)
  processing_fee_type   fee_type_enum?
  processing_fee_value  Decimal?                       @db.Decimal(12, 4)
  processing_mode       payment_processing_mode_enum   @default(ONLINE)
  created_at            DateTime                       @default(now()) @db.Timestamp(6)
  updated_at            DateTime                       @default(now()) @db.Timestamp(6)
  store_payment_methods store_payment_methods[]
}

model store_payment_methods {
  id                       Int                       @id @default(autoincrement())
  store_id                 Int
  system_payment_method_id Int
  display_name             String?                   @db.VarChar(100)
  custom_config            Json?
  state                    payment_method_state_enum @default(enabled)
  display_order            Int                       @default(0)
  min_amount               Decimal?                  @db.Decimal(12, 2)
  max_amount               Decimal?                  @db.Decimal(12, 2)
  created_at               DateTime                  @default(now()) @db.Timestamp(6)
  updated_at               DateTime                  @default(now()) @db.Timestamp(6)
  payments                 payments[]
  stores                   stores                    @relation(fields: [store_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  system_payment_method    system_payment_methods    @relation(fields: [system_payment_method_id], references: [id], onUpdate: NoAction)

  @@unique([store_id, system_payment_method_id])
  @@index([store_id, state])
}

model payments {
  id                      Int                    @id @default(autoincrement())
  order_id                Int
  customer_id             Int?
  amount                  Decimal                @db.Decimal(12, 2)
  currency                String?                @db.VarChar(10)
  state                   payments_state_enum
  transaction_id          String?                @unique @db.VarChar(255)
  gateway_response        Json?
  paid_at                 DateTime?              @db.Timestamp(6)
  created_at              DateTime?              @default(now()) @db.Timestamp(6)
  updated_at              DateTime?              @default(now()) @db.Timestamp(6)
  store_payment_method_id Int?
  orders                  orders                 @relation(fields: [order_id], references: [id], onUpdate: NoAction)
  store_payment_method    store_payment_methods? @relation(fields: [store_payment_method_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  refunds                     refunds[]
  cash_register_movements     cash_register_movements[]
}

model product_categories {
  product_id  Int
  category_id Int
  categories  categories @relation(fields: [category_id], references: [id], onUpdate: NoAction)
  products    products   @relation(fields: [product_id], references: [id], onUpdate: NoAction)

  @@id([product_id, category_id])
}

model product_images {
  id               Int                @id @default(autoincrement())
  product_id       Int?
  image_url        String
  is_main          Boolean?           @default(false)
  alt_text         String?            @db.VarChar(255)
  sort_order       Int?               @default(0)
  created_at       DateTime?          @default(now()) @db.Timestamp(6)
  products         products?          @relation(fields: [product_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  product_variants product_variants[]
}

model product_tax_assignments {
  product_id      Int
  tax_category_id Int
  products        products       @relation(fields: [product_id], references: [id], onUpdate: NoAction)
  tax_categories  tax_categories @relation(fields: [tax_category_id], references: [id], onUpdate: NoAction)

  @@id([product_id, tax_category_id])
}

model product_variants {
  id                       Int                        @id @default(autoincrement())
  product_id               Int
  sku                      String                     @db.VarChar(100)
  name                     String?                    @db.VarChar(255)
  price_override           Decimal?                   @db.Decimal(12, 2)
  cost_price               Decimal?                   @db.Decimal(12, 2)
  profit_margin            Decimal?                   @db.Decimal(5, 2)
  is_on_sale               Boolean                    @default(false)
  sale_price               Decimal?                   @db.Decimal(12, 2)
  stock_quantity           Int                        @default(0)
  attributes               Json?
  image_id                 Int?
  created_at               DateTime?                  @default(now()) @db.Timestamp(6)
  updated_at               DateTime?                  @default(now()) @db.Timestamp(6)
  inventory_adjustments    inventory_adjustments[]
  inventory_batches        inventory_batches[]
  inventory_movements      inventory_movements[]
  inventory_serial_numbers inventory_serial_numbers[]
  inventory_transactions   inventory_transactions[]
  order_items              order_items[]
  product_images           product_images?            @relation(fields: [image_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  products                 products                   @relation(fields: [product_id], references: [id], onUpdate: NoAction)
  purchase_order_items     purchase_order_items[]
  return_order_items       return_order_items[]
  sales_order_items        sales_order_items[]
  stock_levels             stock_levels[]
  stock_reservations       stock_reservations[]
  stock_transfer_items     stock_transfer_items[]
  supplier_products        supplier_products[]        @relation("product_variantsTosupplier_products")
  cart_items               cart_items[]
  wishlist_items           wishlist_items[]
  invoice_items            invoice_items[]
  quotation_items          quotation_items[]
  inventory_cost_layers    inventory_cost_layers[]

  @@unique([product_id, sku])
}

model products {
  id                       Int                        @id @default(autoincrement())
  store_id                 Int
  brand_id                 Int?
  name                     String                     @db.VarChar(255)
  slug                     String                     @db.VarChar(255)
  description              String?
  base_price               Decimal                    @db.Decimal(12, 2)
  cost_price               Decimal?                   @db.Decimal(12, 2)
  profit_margin            Decimal?                   @db.Decimal(5, 2)
  sku                      String?                    @db.VarChar(100)
  stock_quantity           Int?                       @default(0)
  state                    product_state_enum         @default(inactive)
  pricing_type             pricing_type_enum          @default(unit)
  available_for_ecommerce  Boolean                    @default(false)
  is_on_sale               Boolean                    @default(false)
  sale_price               Decimal?                   @db.Decimal(12, 2)
  weight                   Decimal?                   @db.Decimal(12, 3)
  dimensions               Json?
  track_inventory          Boolean                    @default(true)
  min_stock_level          Int?                       @default(0)
  max_stock_level          Int?                       @default(0)
  reorder_point            Int?                       @default(0)
  reorder_quantity         Int?                       @default(0)
  requires_serial_numbers  Boolean                    @default(false)
  requires_batch_tracking  Boolean                    @default(false)
  created_at               DateTime?                  @default(now()) @db.Timestamp(6)
  updated_at               DateTime?                  @default(now()) @db.Timestamp(6)
  inventory_adjustments    inventory_adjustments[]
  inventory_batches        inventory_batches[]
  inventory_movements      inventory_movements[]
  inventory_serial_numbers inventory_serial_numbers[]
  inventory_transactions   inventory_transactions[]
  order_items              order_items[]
  product_categories       product_categories[]
  product_images           product_images[]
  product_tax_assignments  product_tax_assignments[]
  product_variants         product_variants[]
  brands                   brands?                    @relation(fields: [brand_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  stores                   stores                     @relation(fields: [store_id], references: [id], onUpdate: NoAction)
  purchase_order_items     purchase_order_items[]
  return_order_items       return_order_items[]
  reviews                  reviews[]
  sales_order_items        sales_order_items[]
  stock_levels             stock_levels[]
  stock_reservations       stock_reservations[]
  stock_transfer_items     stock_transfer_items[]
  supplier_products        supplier_products[]
  cart_items               cart_items[]
  wishlist_items           wishlist_items[]
  invoice_items            invoice_items[]
  quotation_items          quotation_items[]
  promotion_products       promotion_products[]
  coupon_products          coupon_products[]
  inventory_cost_layers    inventory_cost_layers[]

  @@unique([store_id, slug])
  @@unique([store_id, sku])
  @@index([store_id, sku])
}

model refund_items {
  id               Int                  @id @default(autoincrement())
  refund_id        Int
  order_item_id    Int
  quantity         Int
  refund_amount    Decimal?             @db.Decimal(12, 2)
  tax_amount       Decimal?             @db.Decimal(12, 2)
  discount_amount  Decimal?             @db.Decimal(12, 2)
  inventory_action String?              @default("no_return") @db.VarChar(20)
  location_id      Int?
  reason           String?
  created_at       DateTime?            @default(now()) @db.Timestamp(6)
  order_items      order_items          @relation(fields: [order_item_id], references: [id], onUpdate: NoAction)
  refunds          refunds              @relation(fields: [refund_id], references: [id], onUpdate: NoAction)
  inventory_locations inventory_locations? @relation(fields: [location_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
}

model refunds {
  id                    Int                @id @default(autoincrement())
  order_id              Int
  payment_id            Int?
  customer_id           Int?
  amount                Decimal            @db.Decimal(12, 2)
  subtotal_refund       Decimal?           @default(0) @db.Decimal(12, 2)
  tax_refund            Decimal?           @default(0) @db.Decimal(12, 2)
  shipping_refund       Decimal?           @default(0) @db.Decimal(12, 2)
  currency              String?            @db.VarChar(10)
  reason                String?
  notes                 String?            @db.Text
  state                 refunds_state_enum
  refund_method         String?            @db.VarChar(100)
  refund_transaction_id String?            @unique @db.VarChar(255)
  processed_by_user_id  Int?
  requested_at          DateTime?          @default(now()) @db.Timestamp(6)
  processed_at          DateTime?          @db.Timestamp(6)
  created_at            DateTime?          @default(now()) @db.Timestamp(6)
  updated_at            DateTime?          @default(now()) @db.Timestamp(6)
  refund_items          refund_items[]
  orders                orders             @relation(fields: [order_id], references: [id], onUpdate: NoAction)
  payments              payments?          @relation(fields: [payment_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  users                 users?             @relation(fields: [processed_by_user_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
}

model reviews {
  id         Int               @id @default(autoincrement())
  product_id Int?
  user_id    Int?
  rating     Int?
  comment    String?
  state      review_state_enum @default(pending)
  created_at DateTime?         @default(now()) @db.Timestamp(6)
  products   products?         @relation(fields: [product_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  users      users?            @relation(fields: [user_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
}

model tax_categories {
  id                      Int                       @id @default(autoincrement())
  store_id                Int?
  name                    String                    @db.VarChar(100)
  description             String?
  product_tax_assignments product_tax_assignments[]
  stores                  stores?                   @relation(fields: [store_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  tax_rates               tax_rates[]

  @@unique([store_id, name], name: "store_id_name")
}

model tax_rates {
  id                  Int                @id @default(autoincrement())
  tax_category_id     Int
  store_id            Int?
  country_code        String?            @db.VarChar(3)
  state_province_code String?            @db.VarChar(10)
  postal_code_pattern String?            @db.VarChar(50)
  rate                Decimal            @db.Decimal(6, 5)
  name                String             @db.VarChar(100)
  is_compound         Boolean?           @default(false)
  priority            Int?               @default(0)
  order_item_taxes    order_item_taxes[]
  stores              stores?            @relation(fields: [store_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  tax_categories      tax_categories     @relation(fields: [tax_category_id], references: [id], onUpdate: NoAction)
  invoice_taxes       invoice_taxes[]
}

model api_keys {
  id          Int                 @id @default(autoincrement())
  user_id     Int?
  name        String              @db.VarChar(100)
  key_hash    String              @unique
  permissions Json?
  last_used   DateTime?           @db.Timestamp(6)
  expires_at  DateTime?           @db.Timestamp(6)
  status      api_key_status_enum @default(active)
  created_at  DateTime?           @default(now()) @db.Timestamp(6)
  updated_at  DateTime?           @default(now()) @db.Timestamp(6)
  users       users?              @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model inventory_locations {
  id                       Int                        @id @default(autoincrement())
  organization_id          Int
  store_id                 Int?
  name                     String                     @db.VarChar(255)
  code                     String                     @db.VarChar(50)
  type                     location_type_enum         @default(warehouse)
  is_active                Boolean                    @default(true)
  address_id               Int?
  created_at               DateTime?                  @default(now()) @db.Timestamp(6)
  updated_at               DateTime?                  @default(now()) @db.Timestamp(6)
  inventory_adjustments    inventory_adjustments[]
  inventory_batches        inventory_batches[]
  addresses                addresses?                 @relation("inventory_location_addresses", fields: [address_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  organizations            organizations              @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  stores                   stores?                    @relation(fields: [store_id], references: [id], onDelete: Cascade)
  movements_from           inventory_movements[]      @relation("from_location")
  movements_to             inventory_movements[]      @relation("to_location")
  inventory_serial_numbers inventory_serial_numbers[]
  purchase_orders          purchase_orders[]
  stock_levels             stock_levels[]
  stock_reservations       stock_reservations[]
  transfers_from           stock_transfers[]          @relation("from_location")
  transfers_to             stock_transfers[]          @relation("to_location")
  inventory_cost_layers    inventory_cost_layers[]
  refund_items             refund_items[]

  @@unique([organization_id, code])
  @@index([organization_id, store_id])
  @@index([organization_id, type])
}

model stock_levels {
  id                  Int                 @id @default(autoincrement())
  product_id          Int
  product_variant_id  Int?
  location_id         Int
  quantity_on_hand    Int                 @default(0)
  quantity_reserved   Int                 @default(0)
  quantity_available  Int                 @default(0)
  reorder_point       Int?
  max_stock           Int?
  cost_per_unit       Decimal?            @db.Decimal(12, 4)
  last_updated        DateTime?           @default(now()) @db.Timestamp(6)
  created_at          DateTime?           @default(now()) @db.Timestamp(6)
  updated_at          DateTime?           @default(now()) @db.Timestamp(6)
  inventory_locations inventory_locations @relation(fields: [location_id], references: [id], onDelete: Cascade)
  products            products            @relation(fields: [product_id], references: [id], onDelete: Cascade)
  product_variants    product_variants?   @relation(fields: [product_variant_id], references: [id], onDelete: Cascade)

  @@unique([product_id, product_variant_id, location_id])
  @@index([product_id, location_id])
  @@index([product_id])
  @@index([location_id, quantity_available])
  @@index([quantity_available, reorder_point])
}

model inventory_movements {
  id                 Int                     @id @default(autoincrement())
  organization_id    Int
  product_id         Int
  product_variant_id Int?
  from_location_id   Int?
  to_location_id     Int?
  quantity           Int
  movement_type      movement_type_enum
  source_order_type  source_order_type_enum?
  source_order_id    Int?
  reason             String?
  notes              String?
  user_id            Int?
  created_at         DateTime?               @default(now()) @db.Timestamp(6)
  from_location      inventory_locations?    @relation("from_location", fields: [from_location_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  organizations      organizations           @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  products           products                @relation(fields: [product_id], references: [id], onDelete: Cascade)
  product_variants   product_variants?       @relation(fields: [product_variant_id], references: [id], onDelete: Cascade)
  to_location        inventory_locations?    @relation("to_location", fields: [to_location_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  users              users?                  @relation(fields: [user_id], references: [id], onDelete: Restrict, onUpdate: NoAction)

  @@index([organization_id, product_id, created_at])
  @@index([organization_id, from_location_id, created_at])
  @@index([organization_id, to_location_id, created_at])
  @@index([organization_id, user_id, created_at])
}

model inventory_batches {
  id                       Int                        @id @default(autoincrement())
  product_id               Int
  product_variant_id       Int?
  batch_number             String                     @db.VarChar(100)
  quantity                 Int                        @default(0)
  quantity_used            Int                        @default(0)
  manufacturing_date       DateTime?                  @db.Timestamp(6)
  expiration_date          DateTime?                  @db.Timestamp(6)
  location_id              Int?
  created_at               DateTime?                  @default(now()) @db.Timestamp(6)
  updated_at               DateTime?                  @default(now()) @db.Timestamp(6)
  inventory_locations      inventory_locations?       @relation(fields: [location_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  products                 products                   @relation(fields: [product_id], references: [id], onDelete: Cascade)
  product_variants         product_variants?          @relation(fields: [product_variant_id], references: [id], onDelete: Cascade)
  inventory_serial_numbers inventory_serial_numbers[]
  inventory_adjustments    inventory_adjustments[]

  @@unique([product_id, batch_number])
}

model inventory_serial_numbers {
  id                  Int                  @id @default(autoincrement())
  product_id          Int
  product_variant_id  Int?
  serial_number       String               @unique @db.VarChar(255)
  status              serial_status_enum   @default(in_stock)
  location_id         Int?
  batch_id            Int?
  cost                Decimal?             @db.Decimal(12, 4)
  sold_date           DateTime?            @db.Timestamp(6)
  warranty_expiry     DateTime?            @db.Timestamp(6)
  notes               String?
  created_at          DateTime?            @default(now()) @db.Timestamp(6)
  updated_at          DateTime?            @default(now()) @db.Timestamp(6)
  inventory_batches   inventory_batches?   @relation(fields: [batch_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  inventory_locations inventory_locations? @relation(fields: [location_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  products            products             @relation(fields: [product_id], references: [id], onDelete: Cascade)
  product_variants    product_variants?    @relation(fields: [product_variant_id], references: [id], onDelete: Cascade)
}

model suppliers {
  id                Int                 @id @default(autoincrement())
  organization_id   Int
  name              String              @db.VarChar(255)
  code              String              @db.VarChar(50)
  contact_person    String?             @db.VarChar(255)
  mobile            String?             @db.VarChar(50)
  email             String?             @db.VarChar(255)
  phone             String?             @db.VarChar(50)
  website           String?             @db.VarChar(255)
  tax_id            String?             @db.VarChar(50)
  payment_terms     String?             @db.VarChar(255)
  currency          String?             @db.VarChar(10)
  notes             String?
  lead_time_days    Int?
  is_active         Boolean             @default(true)
  address_id        Int?
  created_at        DateTime?           @default(now()) @db.Timestamp(6)
  updated_at        DateTime?           @default(now()) @db.Timestamp(6)
  purchase_orders   purchase_orders[]
  supplier_products supplier_products[]
  organizations     organizations       @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  addresses         addresses?          @relation("supplier_addresses", fields: [address_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  invoices          invoices[]

  @@unique([organization_id, code])
  @@index([organization_id, name])
}

model supplier_products {
  id               Int                @id @default(autoincrement())
  supplier_id      Int
  product_id       Int
  supplier_sku     String?            @db.VarChar(100)
  cost_per_unit    Decimal?           @db.Decimal(12, 4)
  min_order_qty    Int?
  lead_time_days   Int?
  is_preferred     Boolean            @default(false)
  created_at       DateTime?          @default(now()) @db.Timestamp(6)
  updated_at       DateTime?          @default(now()) @db.Timestamp(6)
  products         products           @relation(fields: [product_id], references: [id], onDelete: Cascade)
  suppliers        suppliers          @relation(fields: [supplier_id], references: [id], onDelete: Cascade)
  product_variants product_variants[] @relation("product_variantsTosupplier_products")

  @@unique([supplier_id, product_id])
}

model expenses {
  id                  Int                 @id @default(autoincrement())
  store_id            Int
  organization_id     Int
  category_id         Int?
  amount              Decimal             @db.Decimal(12, 2)
  currency            String?             @db.VarChar(10)
  description         String?             @db.VarChar(500)
  expense_date        DateTime            @db.Timestamp(6)
  state               expenses_state_enum @default(pending)
  receipt_url         String?             @db.Text
  notes               String?             @db.Text
  created_by_user_id  Int?
  approved_by_user_id Int?
  approved_at         DateTime?           @db.Timestamp(6)
  created_at          DateTime?           @default(now()) @db.Timestamp(6)
  updated_at          DateTime?           @default(now()) @db.Timestamp(6)

  stores             stores              @relation(fields: [store_id], references: [id], onDelete: Cascade)
  organizations      organizations       @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  expense_categories expense_categories? @relation(fields: [category_id], references: [id])
