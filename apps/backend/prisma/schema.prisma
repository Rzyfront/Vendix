model purchase_orders {
  id                    Int                                @id @default(autoincrement())
  organization_id       Int
  supplier_id           Int
  location_id           Int
  order_number          String                             @db.VarChar(50)
  status                purchase_order_status_enum         @default(draft)
  order_date            DateTime?                          @default(now()) @db.Timestamp(6)
  expected_date         DateTime?                          @db.Timestamp(6)
  received_date         DateTime?                          @db.Timestamp(6)
  subtotal_amount       Decimal                            @default(0.00) @db.Decimal(12, 2)
  tax_amount            Decimal                            @default(0.00) @db.Decimal(12, 2)
  total_amount          Decimal                            @default(0.00) @db.Decimal(12, 2)
  discount_amount       Decimal                            @default(0.00) @db.Decimal(12, 2)
  shipping_cost         Decimal                            @default(0.00) @db.Decimal(12, 2)
  payment_terms         String?                            @db.VarChar(255)
  shipping_method       String?                            @db.VarChar(100)
  notes                 String?
  internal_notes        String?
  created_by_user_id    Int?
  approved_by_user_id   Int?
  created_at            DateTime?                          @default(now()) @db.Timestamp(6)
  updated_at            DateTime?                          @default(now()) @db.Timestamp(6)
  payment_status        purchase_order_payment_status_enum @default(unpaid)
  payment_due_date      DateTime?                          @db.Timestamp(6)
  purchase_order_items  purchase_order_items[]
  users                 users?                             @relation("purchase_orders_approved_by", fields: [approved_by_user_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  users1                users?                             @relation("purchase_orders_created_by", fields: [created_by_user_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  location              inventory_locations                @relation(fields: [location_id], references: [id], onUpdate: NoAction)
  organizations         organizations                      @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  suppliers             suppliers                          @relation(fields: [supplier_id], references: [id], onUpdate: NoAction)
  inventory_cost_layers inventory_cost_layers[]
  attachments           purchase_order_attachments[]
  payments              purchase_order_payments[]
  receptions            purchase_order_receptions[]

  @@unique([organization_id, order_number])
}

model purchase_order_items {
  id                 Int                              @id @default(autoincrement())
  purchase_order_id  Int
  product_id         Int
  product_variant_id Int?
  quantity_ordered   Int
  quantity_received  Int                              @default(0)
  unit_cost          Decimal?                         @db.Decimal(12, 4)
  total_cost         Decimal?                         @db.Decimal(12, 2)
  notes              String?
  batch_number       String?                          @db.VarChar(100)
  manufacturing_date DateTime?                        @db.Timestamp(6)
  expiration_date    DateTime?                        @db.Timestamp(6)
  created_at         DateTime?                        @default(now()) @db.Timestamp(6)
  products           products                         @relation(fields: [product_id], references: [id], onDelete: Cascade)
  product_variants   product_variants?                @relation(fields: [product_variant_id], references: [id], onDelete: Cascade)
  purchase_orders    purchase_orders                  @relation(fields: [purchase_order_id], references: [id], onDelete: Cascade)
  reception_items    purchase_order_reception_items[]

  @@index([purchase_order_id])
  @@index([product_id, purchase_order_id])
}

model purchase_order_attachments {
  id                      Int       @id @default(autoincrement())
  purchase_order_id       Int
  file_url                String    @db.VarChar(500)
  file_name               String    @db.VarChar(255)
  file_type               String    @db.VarChar(100)
  file_size               Int
  supplier_invoice_number String?   @db.VarChar(100)
  supplier_invoice_date   DateTime?
  supplier_invoice_amount Decimal?  @db.Decimal(12, 2)
