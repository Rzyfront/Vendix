  @@unique([organization_id, name])
}

model inventory_adjustments {
  id                                                     Int                  @id @default(autoincrement())
  organization_id                                        Int
  product_id                                             Int
  product_variant_id                                     Int?
  location_id                                            Int
  batch_id                                               Int?
  adjustment_type                                        adjustment_type_enum
  quantity_before                                        Int
  quantity_after                                         Int
  quantity_change                                        Int
  reason_code                                            String?              @db.VarChar(50)
  description                                            String?
  approved_by_user_id                                    Int?
  created_by_user_id                                     Int?
  approved_at                                            DateTime?            @db.Timestamp(6)
  created_at                                             DateTime?            @default(now()) @db.Timestamp(6)
  users_inventory_adjustments_approved_by_user_idTousers users?               @relation("inventory_adjustments_approved_by", fields: [approved_by_user_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  users_inventory_adjustments_created_by_user_idTousers  users?               @relation("inventory_adjustments_created_by", fields: [created_by_user_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
