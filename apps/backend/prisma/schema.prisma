enum cash_register_session_status_enum {
  open
  closed
  suspended
}

enum cash_register_movement_type_enum {
  opening_balance
  sale
  refund
  cash_in
  cash_out
  closing_balance
}

model cash_registers {
  id                     Int       @id @default(autoincrement())
