  partner_id         Int?
  partner_type       partner_type_enum?
  type               return_order_type_enum
  status             return_order_status_enum @default(draft)
  reason_id          Int?
  created_at         DateTime?                @default(now()) @db.Timestamp(6)
  updated_at         DateTime?                @default(now()) @db.Timestamp(6)
  return_order_items return_order_items[]
  organizations      organizations            @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([organization_id, type, status])
