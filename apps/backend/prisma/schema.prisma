model support_tickets {
  id                  Int                     @id @default(autoincrement())
  ticket_number       String                  @unique
  organization_id     Int
  store_id            Int?
  created_by_user_id  Int
  created_by          users                   @relation("ticket_creator", fields: [created_by_user_id], references: [id], onDelete: Restrict)
  title               String                  @db.VarChar(255)
  description         String                  @db.Text
  category            ticket_category_enum    @default(QUESTION)
  priority            ticket_priority_enum    @default(P3)
  status              ticket_status_enum      @default(NEW)
  assigned_to_user_id Int?
  assigned_to         users?                  @relation("ticket_assigned", fields: [assigned_to_user_id], references: [id], onDelete: SetNull)
  related_order_id    Int?
  related_order_type  String?                 @db.VarChar(50)
  related_product_id  Int?
  sla_deadline        DateTime?               @db.Timestamp(6)
  sla_breached        Boolean                 @default(false)
  first_response_at   DateTime?               @db.Timestamp(6)
  resolved_at         DateTime?               @db.Timestamp(6)
  closed_at           DateTime?               @db.Timestamp(6)
  resolution_summary  String?                 @db.Text
  resolution_time_minutes Int?
  customer_satisfied  Boolean?
  source_channel      String                  @default("web")
  tags                String[]                @default([])
  created_at          DateTime?               @default(now()) @db.Timestamp(6)
  updated_at          DateTime?               @default(now()) @db.Timestamp(6)
  organization        organizations           @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  store               stores?                 @relation(fields: [store_id], references: [id], onDelete: Cascade)
  attachments         support_attachments[]
  comments            support_comments[]
  status_history      support_status_history[]
  notifications       support_notifications[]

  @@unique([organization_id, ticket_number], name: "support_tickets_organization_id_ticket_number_key")
  @@index([organization_id, status], name: "support_tickets_organization_id_status_idx")
  @@index([store_id, status], name: "support_tickets_store_id_status_idx")
  @@index([created_by_user_id, status], name: "support_tickets_created_by_user_id_status_idx")
  @@index([assigned_to_user_id, status], name: "support_tickets_assigned_to_user_id_status_idx")
  @@index([priority, status], name: "support_tickets_priority_status_idx")
  @@index([created_at], name: "support_tickets_created_at_idx")
  @@index([sla_deadline], name: "support_tickets_sla_deadline_idx")
}

model support_attachments {
  id              Int                        @id @default(autoincrement())
  ticket_id       Int
  file_name       String
  file_key        String
  file_url        String?                    @db.Text
  file_size       Int
  file_type       ticket_attachment_type_enum
  mime_type       String
  thumbnail_key   String?
  thumbnail_url   String?                    @db.Text
  width           Int?
  height          Int?
  uploaded_by_user_id Int?
  description     String?                    @db.Text
  created_at      DateTime?                  @default(now()) @db.Timestamp(6)
  ticket          support_tickets            @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  uploaded_by     users?                     @relation("attachment_uploaded_by", fields: [uploaded_by_user_id], references: [id], onDelete: SetNull)

  @@index([ticket_id], name: "support_attachments_ticket_id_idx")
  @@index([file_type], name: "support_attachments_file_type_idx")
}

model support_comments {
  id              Int                        @id @default(autoincrement())
  ticket_id       Int
  content         String                    @db.Text
  is_internal     Boolean                   @default(false)
  author_id       Int
  author_type     String
  author_name     String
  author_email    String?
  created_at      DateTime?                  @default(now()) @db.Timestamp(6)
  updated_at      DateTime?                  @default(now()) @db.Timestamp(6)
  ticket          support_tickets            @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  author          users                     @relation("comment_author", fields: [author_id], references: [id], onDelete: Restrict)

  @@index([ticket_id, created_at], name: "support_comments_ticket_id_created_at_idx")
  @@index([author_id], name: "support_comments_author_id_idx")
}

model support_status_history {
  id                  Int                     @id @default(autoincrement())
  ticket_id           Int
