  invoices                 invoices[]
  withholding_calculations withholding_calculations[]
  accounts_payable         accounts_payable[]         @relation("supplier_accounts_payable")

  @@unique([organization_id, code])
  @@index([organization_id, name])
}

model supplier_products {
  id               Int                @id @default(autoincrement())
  supplier_id      Int
  product_id       Int
  supplier_sku     String?            @db.VarChar(100)
