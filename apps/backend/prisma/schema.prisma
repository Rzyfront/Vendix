  // Relaciones
  document legal_documents @relation(fields: [document_id], references: [id], onDelete: Cascade)
  user     users           @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, document_id, acceptance_version])
  @@index([user_id])
  @@index([document_id, accepted_at])
  @@index([accepted_at])
}

