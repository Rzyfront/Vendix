  organization_id     Int
  store_id            Int?
  user_id             Int?
  employee_code       String                 @db.VarChar(50)
  first_name          String                 @db.VarChar(100)
  last_name           String                 @db.VarChar(100)
  document_type       String                 @db.VarChar(20)
  document_number     String                 @db.VarChar(50)
  hire_date           DateTime               @db.Timestamp(6)
  termination_date    DateTime?              @db.Timestamp(6)
  status              employee_status_enum   @default(active)
  contract_type       contract_type_enum
  position            String?                @db.VarChar(100)
  department          String?                @db.VarChar(100)
  cost_center         cost_center_enum       @default(administrative)
  base_salary         Decimal                @db.Decimal(12, 2)
  payment_frequency   payroll_frequency_enum @default(monthly)
  bank_name           String?                @db.VarChar(100)
  bank_account_number String?                @db.VarChar(50)
  bank_account_type   String?                @db.VarChar(20)
  health_provider     String?                @db.VarChar(100)
  pension_fund        String?                @db.VarChar(100)
  arl_risk_level      Int?                   @default(1)
  severance_fund      String?                @db.VarChar(100)
  compensation_fund   String?                @db.VarChar(100)
