  document_type  legal_document_type_enum
  title          String                   @db.VarChar(255)
  version        String                   @db.VarChar(20)
  content        String                   @db.Text
  description    String?                  @db.Text
  effective_date DateTime                 @db.Timestamp(6)
  expiry_date    DateTime?                @db.Timestamp(6)
  is_active      Boolean                  @default(true)
  is_system      Boolean                  @default(false)
  document_url   String?                  @db.Text

  // Scope del documento
  organization_id Int?
  store_id        Int?

  // Auditoría de cambios
  created_by_user_id Int?
  created_at         DateTime? @default(now()) @db.Timestamp(6)
  updated_at         DateTime? @default(now()) @db.Timestamp(6)

  // Relaciones
  document_acceptances document_acceptances[]

  @@unique([version, store_id, organization_id, document_type])
  @@index([document_type, is_active])
  @@index([effective_date])
  @@index([organization_id])
  @@index([store_id])
  @@index([document_type, organization_id, is_active])
  @@index([document_type, store_id, is_active])
}

model document_acceptances {
