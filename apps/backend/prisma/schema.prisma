  @@index([dian_configuration_id])
  @@index([action])
  @@index([created_at])
}

// ===== QUOTATIONS =====

enum quotation_status_enum {
  draft
  sent
  accepted
  rejected
  expired
  converted
  cancelled
}

model quotations {
  id                    Int                      @id @default(autoincrement())
  store_id              Int
  customer_id           Int?
  quotation_number      String                   @db.VarChar(50)
  status                quotation_status_enum    @default(draft)
  channel               order_channel_enum       @default(pos)
  subtotal_amount       Decimal                  @default(0.00) @db.Decimal(12, 2)
  discount_amount       Decimal                  @default(0.00) @db.Decimal(12, 2)
  tax_amount            Decimal                  @default(0.00) @db.Decimal(12, 2)
  shipping_cost         Decimal                  @default(0.00) @db.Decimal(12, 2)
  grand_total           Decimal                  @default(0.00) @db.Decimal(12, 2)
  valid_until           DateTime?                @db.Timestamp(6)
  notes                 String?                  @db.Text
  internal_notes        String?                  @db.Text
  terms_and_conditions  String?                  @db.Text
  sent_at               DateTime?                @db.Timestamp(6)
  accepted_at           DateTime?                @db.Timestamp(6)
  rejected_at           DateTime?                @db.Timestamp(6)
  converted_at          DateTime?                @db.Timestamp(6)
  converted_order_id    Int?
  created_by_user_id    Int?
  created_at            DateTime?                @default(now()) @db.Timestamp(6)
  updated_at            DateTime?                @default(now()) @db.Timestamp(6)

  quotation_items       quotation_items[]
  store                 stores                   @relation(fields: [store_id], references: [id], onUpdate: NoAction)
  customer              users?                   @relation("quotations_customer", fields: [customer_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  converted_order       orders?                  @relation(fields: [converted_order_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  created_by_user       users?                   @relation("quotations_created_by", fields: [created_by_user_id], references: [id], onDelete: Restrict, onUpdate: NoAction)

  @@unique([store_id, quotation_number])
  @@index([store_id, quotation_number])
  @@index([store_id, status])
  @@index([customer_id])
}

model quotation_items {
  id                 Int               @id @default(autoincrement())
  quotation_id       Int
  product_id         Int?
  product_variant_id Int?
  product_name       String            @db.VarChar(255)
  variant_sku        String?           @db.VarChar(100)
  quantity           Int
  unit_price         Decimal           @db.Decimal(12, 2)
  discount_amount    Decimal           @default(0.00) @db.Decimal(12, 2)
  tax_rate           Decimal?          @db.Decimal(6, 5)
  tax_amount_item    Decimal?          @db.Decimal(12, 2)
  total_price        Decimal           @db.Decimal(12, 2)
  notes              String?           @db.Text
  created_at         DateTime?         @default(now()) @db.Timestamp(6)
  updated_at         DateTime?         @default(now()) @db.Timestamp(6)

  quotation          quotations        @relation(fields: [quotation_id], references: [id], onDelete: Cascade)
  product            products?         @relation(fields: [product_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  product_variant    product_variants? @relation(fields: [product_variant_id], references: [id], onDelete: Restrict, onUpdate: NoAction)

  @@index([quotation_id])
  @@index([product_id, quotation_id])
}

// ===== COUPONS SYSTEM =====

enum coupon_discount_type {
  PERCENTAGE
  FIXED_AMOUNT
}

enum coupon_applies_to {
  ALL_PRODUCTS
  SPECIFIC_PRODUCTS
  SPECIFIC_CATEGORIES
}

model coupons {
  id                   Int                  @id @default(autoincrement())
  store_id             Int
  code                 String               @db.VarChar(50)
  name                 String               @db.VarChar(255)
  description          String?
  discount_type        coupon_discount_type
  discount_value       Decimal              @db.Decimal(12, 2)
  min_purchase_amount  Decimal?             @db.Decimal(12, 2)
  max_discount_amount  Decimal?             @db.Decimal(12, 2)
  max_uses             Int?
  max_uses_per_customer Int?                @default(1)
  current_uses         Int                  @default(0)
  valid_from           DateTime             @db.Timestamp(6)
  valid_until          DateTime             @db.Timestamp(6)
  is_active            Boolean              @default(true)
  applies_to           coupon_applies_to    @default(ALL_PRODUCTS)
  created_at           DateTime?            @default(now()) @db.Timestamp(6)
  updated_at           DateTime?            @default(now()) @db.Timestamp(6)

  store              stores               @relation(fields: [store_id], references: [id], onUpdate: NoAction)
  coupon_products    coupon_products[]
  coupon_categories  coupon_categories[]
  coupon_uses        coupon_uses[]
  orders             orders[]

  @@unique([store_id, code])
  @@index([store_id, is_active])
}

model coupon_products {
  id         Int      @id @default(autoincrement())
  coupon_id  Int
  product_id Int

  coupon   coupons  @relation(fields: [coupon_id], references: [id], onDelete: Cascade)
  product  products @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([coupon_id, product_id])
  @@index([coupon_id])
}

model coupon_categories {
  id          Int @id @default(autoincrement())
  coupon_id   Int
  category_id Int

  coupon   coupons    @relation(fields: [coupon_id], references: [id], onDelete: Cascade)
  category categories @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@unique([coupon_id, category_id])
  @@index([coupon_id])
}

model coupon_uses {
  id               Int      @id @default(autoincrement())
  coupon_id        Int
  order_id         Int
  customer_id      Int?
  discount_applied Decimal  @db.Decimal(12, 2)
  used_at          DateTime @default(now()) @db.Timestamp(6)

  coupon   coupons @relation(fields: [coupon_id], references: [id], onDelete: Cascade)
  order    orders  @relation(fields: [order_id], references: [id], onDelete: Cascade)
  customer users?  @relation(fields: [customer_id], references: [id], onDelete: Restrict, onUpdate: NoAction)

  @@index([coupon_id, customer_id])
  @@index([order_id])
}

model inventory_cost_layers {
  id                 Int               @id @default(autoincrement())
  organization_id    Int
  product_id         Int
  product_variant_id Int?
  location_id        Int
  purchase_order_id  Int?
  quantity_remaining Int               @default(0)
  unit_cost          Decimal           @db.Decimal(12, 4)
  received_at        DateTime          @default(now()) @db.Timestamp(6)
  batch_number       String?           @db.VarChar(100)
  manufacturing_date DateTime?         @db.Timestamp(6)
  expiration_date    DateTime?         @db.Timestamp(6)
  created_at         DateTime?         @default(now()) @db.Timestamp(6)

  organizations       organizations        @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  products            products             @relation(fields: [product_id], references: [id], onDelete: Cascade)
  product_variants    product_variants?    @relation(fields: [product_variant_id], references: [id], onDelete: Cascade)
  inventory_locations inventory_locations  @relation(fields: [location_id], references: [id], onDelete: Cascade)
  purchase_orders     purchase_orders?     @relation(fields: [purchase_order_id], references: [id])

  @@index([product_id, product_variant_id, location_id, received_at])
  @@index([organization_id])
}

// ============================================================================
// CASH REGISTER MODULE
// ============================================================================

enum cash_register_session_status_enum {
  open
  closed
  suspended
}

enum cash_register_movement_type_enum {
  opening_balance
  sale
  refund
  cash_in
  cash_out
  closing_balance
}

model cash_registers {
  id                     Int       @id @default(autoincrement())
  store_id               Int
  name                   String    @db.VarChar(100)
  code                   String    @db.VarChar(50)
  description            String?   @db.VarChar(255)
  is_active              Boolean   @default(true)
  default_opening_amount Decimal?  @db.Decimal(12, 2)
  created_at             DateTime? @default(now()) @db.Timestamp(6)
  updated_at             DateTime? @default(now()) @db.Timestamp(6)

  store    stores                   @relation(fields: [store_id], references: [id], onUpdate: NoAction)
  sessions cash_register_sessions[]

  @@unique([store_id, code])
  @@index([store_id, is_active])
}

model cash_register_sessions {
  id                      Int                                @id @default(autoincrement())
  cash_register_id        Int
  store_id                Int
  opened_by               Int
  closed_by               Int?
  status                  cash_register_session_status_enum  @default(open)
  opened_at               DateTime                           @default(now()) @db.Timestamp(6)
  closed_at               DateTime?                          @db.Timestamp(6)
  opening_amount          Decimal                            @db.Decimal(12, 2)
  expected_closing_amount Decimal?                           @db.Decimal(12, 2)
  actual_closing_amount   Decimal?                           @db.Decimal(12, 2)
  difference              Decimal?                           @db.Decimal(12, 2)
  closing_notes           String?
  summary                 Json?
  created_at              DateTime?                          @default(now()) @db.Timestamp(6)
  updated_at              DateTime?                          @default(now()) @db.Timestamp(6)

  cash_register stores                     @relation("cash_register_sessions_store", fields: [store_id], references: [id], onUpdate: NoAction)
  register      cash_registers             @relation(fields: [cash_register_id], references: [id], onUpdate: NoAction)
  opened_by_user  users                    @relation("cash_register_sessions_opened_by", fields: [opened_by], references: [id], onUpdate: NoAction)
  closed_by_user  users?                   @relation("cash_register_sessions_closed_by", fields: [closed_by], references: [id], onUpdate: NoAction)
  movements     cash_register_movements[]

  @@index([store_id, status])
  @@index([cash_register_id, status])
  @@index([opened_by, status])
}

model cash_register_movements {
  id             Int                                @id @default(autoincrement())
  session_id     Int
  store_id       Int
  user_id        Int
  type           cash_register_movement_type_enum
  amount         Decimal                            @db.Decimal(12, 2)
  payment_method String?                            @db.VarChar(50)
  reference      String?                            @db.VarChar(255)
  order_id       Int?
  payment_id     Int?
  notes          String?
  created_at     DateTime?                          @default(now()) @db.Timestamp(6)

  session  cash_register_sessions @relation(fields: [session_id], references: [id], onUpdate: NoAction)
  store    stores                 @relation(fields: [store_id], references: [id], onUpdate: NoAction)
  user     users                  @relation(fields: [user_id], references: [id], onUpdate: NoAction)
  order    orders?                @relation(fields: [order_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  payment  payments?              @relation(fields: [payment_id], references: [id], onDelete: Restrict, onUpdate: NoAction)

  @@index([session_id, type])
  @@index([store_id])
  @@index([order_id])
}
