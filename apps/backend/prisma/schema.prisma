  @@index([purchase_order_id])
}

model purchase_order_receptions {
  id                  Int      @id @default(autoincrement())
  purchase_order_id   Int
  received_by_user_id Int?
  notes               String?  @db.Text
  received_at         DateTime @default(now())

  purchase_order purchase_orders                  @relation(fields: [purchase_order_id], references: [id], onDelete: Cascade)
  received_by    users?                           @relation("po_reception_receiver", fields: [received_by_user_id], references: [id])
