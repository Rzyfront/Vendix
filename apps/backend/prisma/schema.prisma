// ===== BANK RECONCILIATION DOMAIN =====

model bank_accounts {
  id               Int                      @id @default(autoincrement())
  organization_id  Int
  store_id         Int?
  name             String                   @db.VarChar(100)
  account_number   String                   @db.VarChar(50)
  bank_name        String                   @db.VarChar(100)
  bank_code        String?                  @db.VarChar(20)
  currency         String                   @default("COP") @db.VarChar(10)
  opening_balance  Decimal                  @default(0) @db.Decimal(12, 2)
  current_balance  Decimal                  @default(0) @db.Decimal(12, 2)
  status           bank_account_status_enum @default(active)
  chart_account_id Int?
  column_mapping   Json?
  created_at       DateTime?                @default(now()) @db.Timestamp(6)
  updated_at       DateTime?                @default(now()) @db.Timestamp(6)

  organization         organizations          @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  store                stores?                @relation(fields: [store_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  chart_account        chart_of_accounts?     @relation(fields: [chart_account_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  bank_transactions    bank_transactions[]
  bank_reconciliations bank_reconciliations[]

  @@unique([organization_id, account_number])
  @@index([organization_id, store_id])
}

model bank_transactions {
  id               Int                        @id @default(autoincrement())
  bank_account_id  Int
  transaction_date DateTime                   @db.Date
  value_date       DateTime?                  @db.Date
  description      String                     @db.VarChar(500)
  amount           Decimal                    @db.Decimal(12, 2)
  type             bank_transaction_type_enum
  reference        String?                    @db.VarChar(255)
  external_id      String?                    @db.VarChar(255)
  counterparty     String?                    @db.VarChar(255)
  is_reconciled    Boolean                    @default(false)
  imported_at      DateTime?                  @default(now()) @db.Timestamp(6)
  created_at       DateTime?                  @default(now()) @db.Timestamp(6)
  updated_at       DateTime?                  @default(now()) @db.Timestamp(6)

  bank_account                bank_accounts                 @relation(fields: [bank_account_id], references: [id], onDelete: Cascade)
  bank_reconciliation_matches bank_reconciliation_matches[]

  @@unique([bank_account_id, external_id])
  @@index([bank_account_id, transaction_date])
  @@index([bank_account_id, is_reconciled])
}

model bank_reconciliations {
  id                 Int                             @id @default(autoincrement())
  bank_account_id    Int
  period_start       DateTime                        @db.Date
  period_end         DateTime                        @db.Date
  opening_balance    Decimal                         @db.Decimal(12, 2)
  statement_balance  Decimal                         @db.Decimal(12, 2)
  reconciled_balance Decimal                         @default(0) @db.Decimal(12, 2)
  difference         Decimal                         @default(0) @db.Decimal(12, 2)
  status             bank_reconciliation_status_enum @default(draft)
  completed_at       DateTime?                       @db.Timestamp(6)
  created_by_user_id Int?
  created_at         DateTime?                       @default(now()) @db.Timestamp(6)
  updated_at         DateTime?                       @default(now()) @db.Timestamp(6)

  bank_account bank_accounts                 @relation(fields: [bank_account_id], references: [id], onDelete: Cascade)
  created_by   users?                        @relation("bank_reconciliations_created_by", fields: [created_by_user_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  matches      bank_reconciliation_matches[]

  @@index([bank_account_id, period_start])
}

model bank_reconciliation_matches {
  id                  Int                                 @id @default(autoincrement())
  reconciliation_id   Int
  bank_transaction_id Int
  accounting_entry_id Int?
  match_type          bank_reconciliation_match_type_enum
  confidence_score    Decimal?                            @db.Decimal(5, 2)
  notes               String?                             @db.VarChar(500)
  matched_at          DateTime?                           @default(now()) @db.Timestamp(6)
  matched_by_user_id  Int?

  reconciliation   bank_reconciliations @relation(fields: [reconciliation_id], references: [id], onDelete: Cascade)
  bank_transaction bank_transactions    @relation(fields: [bank_transaction_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  accounting_entry accounting_entries?  @relation(fields: [accounting_entry_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  matched_by       users?               @relation("bank_reconciliation_matches_matched_by", fields: [matched_by_user_id], references: [id], onDelete: Restrict, onUpdate: NoAction)

  @@unique([reconciliation_id, bank_transaction_id])
  @@index([reconciliation_id])
}

// ===== FIXED ASSETS DOMAIN =====

model fixed_asset_categories {
  id                          Int                      @id @default(autoincrement())
  organization_id             Int
  name                        String                   @db.VarChar(150)
  default_useful_life_months  Int                      @default(60)
  default_depreciation_method depreciation_method_enum @default(straight_line)
  default_salvage_percentage  Decimal                  @default(0) @db.Decimal(5, 2)
  depreciation_account_code   String?                  @db.VarChar(20)
  expense_account_code        String?                  @db.VarChar(20)
  is_active                   Boolean                  @default(true)
  created_at                  DateTime?                @default(now()) @db.Timestamp(6)
  updated_at                  DateTime?                @default(now()) @db.Timestamp(6)

  organization organizations  @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  fixed_assets fixed_assets[]

  @@index([organization_id])
}

model fixed_assets {
  id                       Int                      @id @default(autoincrement())
  organization_id          Int
  store_id                 Int?
  category_id              Int?
  asset_number             String                   @db.VarChar(50)
  name                     String                   @db.VarChar(255)
  description              String?                  @db.VarChar(500)
  acquisition_date         DateTime                 @db.Date
  acquisition_cost         Decimal                  @db.Decimal(12, 2)
  salvage_value            Decimal                  @default(0) @db.Decimal(12, 2)
  useful_life_months       Int
  depreciation_method      depreciation_method_enum @default(straight_line)
  status                   fixed_asset_status_enum  @default(active)
  accumulated_depreciation Decimal                  @default(0) @db.Decimal(12, 2)
  depreciation_start_date  DateTime?                @db.Date
  retirement_date          DateTime?                @db.Date
  disposal_date            DateTime?                @db.Date
  disposal_amount          Decimal?                 @db.Decimal(12, 2)
  notes                    String?                  @db.VarChar(1000)
  created_by_user_id       Int?
  created_at               DateTime?                @default(now()) @db.Timestamp(6)
  updated_at               DateTime?                @default(now()) @db.Timestamp(6)

  organization         organizations           @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  store                stores?                 @relation(fields: [store_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  category             fixed_asset_categories? @relation(fields: [category_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  created_by_user      users?                  @relation("fixed_assets_created_by", fields: [created_by_user_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  depreciation_entries depreciation_entries[]

  @@unique([organization_id, asset_number])
  @@index([organization_id, store_id])
  @@index([status])
}

model depreciation_entries {
  id                  Int                            @id @default(autoincrement())
  fixed_asset_id      Int
  period_date         DateTime                       @db.Date
  depreciation_amount Decimal                        @db.Decimal(12, 2)
  accumulated_total   Decimal                        @db.Decimal(12, 2)
  book_value          Decimal                        @db.Decimal(12, 2)
  accounting_entry_id Int?
  status              depreciation_entry_status_enum @default(pending)
  created_at          DateTime?                      @default(now()) @db.Timestamp(6)

  fixed_asset      fixed_assets        @relation(fields: [fixed_asset_id], references: [id], onDelete: Cascade)
  accounting_entry accounting_entries? @relation("depreciation_accounting_entry", fields: [accounting_entry_id], references: [id], onDelete: Restrict, onUpdate: NoAction)

  @@unique([fixed_asset_id, period_date])
  @@index([status])
}

// ===== BUDGETS DOMAIN =====

model budgets {
  id                  Int                @id @default(autoincrement())
  organization_id     Int
  store_id            Int?
  fiscal_period_id    Int
  name                String             @db.VarChar(255)
  description         String?            @db.VarChar(500)
  status              budget_status_enum @default(draft)
  variance_threshold  Decimal?           @default(10) @db.Decimal(5, 2)
  approved_by_user_id Int?
  approved_at         DateTime?          @db.Timestamp(6)
  created_by_user_id  Int?
  created_at          DateTime?          @default(now()) @db.Timestamp(6)
  updated_at          DateTime?          @default(now()) @db.Timestamp(6)

  organization  organizations  @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  store         stores?        @relation(fields: [store_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  fiscal_period fiscal_periods @relation(fields: [fiscal_period_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  approved_by   users?         @relation("budgets_approved_by", fields: [approved_by_user_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  created_by    users?         @relation("budgets_created_by", fields: [created_by_user_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  budget_lines  budget_lines[]

  @@unique([organization_id, store_id, fiscal_period_id, name])
  @@index([organization_id, fiscal_period_id])
}

model budget_lines {
  id             Int       @id @default(autoincrement())
  budget_id      Int
  account_id     Int
  month_01       Decimal   @default(0) @db.Decimal(12, 2)
  month_02       Decimal   @default(0) @db.Decimal(12, 2)
  month_03       Decimal   @default(0) @db.Decimal(12, 2)
  month_04       Decimal   @default(0) @db.Decimal(12, 2)
  month_05       Decimal   @default(0) @db.Decimal(12, 2)
  month_06       Decimal   @default(0) @db.Decimal(12, 2)
  month_07       Decimal   @default(0) @db.Decimal(12, 2)
  month_08       Decimal   @default(0) @db.Decimal(12, 2)
  month_09       Decimal   @default(0) @db.Decimal(12, 2)
  month_10       Decimal   @default(0) @db.Decimal(12, 2)
  month_11       Decimal   @default(0) @db.Decimal(12, 2)
  month_12       Decimal   @default(0) @db.Decimal(12, 2)
  total_budgeted Decimal   @default(0) @db.Decimal(12, 2)
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  updated_at     DateTime? @default(now()) @db.Timestamp(6)

  budget  budgets           @relation(fields: [budget_id], references: [id], onDelete: Cascade)
  account chart_of_accounts @relation(fields: [account_id], references: [id], onDelete: Restrict, onUpdate: NoAction)

  @@unique([budget_id, account_id])
  @@index([budget_id])
  @@index([account_id])
}

// ===== CONSOLIDATION DOMAIN =====

model consolidation_sessions {
  id                 Int                       @id @default(autoincrement())
  organization_id    Int
  fiscal_period_id   Int
  name               String                    @db.VarChar(255)
  session_date       DateTime                  @db.Timestamp(6)
  status             consolidation_status_enum @default(draft)
  notes              String?                   @db.VarChar(1000)
  created_by_user_id Int?
  completed_at       DateTime?                 @db.Timestamp(6)
  created_at         DateTime?                 @default(now()) @db.Timestamp(6)
  updated_at         DateTime?                 @default(now()) @db.Timestamp(6)

  organization      organizations               @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  fiscal_period     fiscal_periods              @relation(fields: [fiscal_period_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  created_by        users?                      @relation("consolidation_created_by", fields: [created_by_user_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  adjustments       consolidation_adjustments[]
  intercompany_txns intercompany_transactions[]

  @@index([organization_id, fiscal_period_id])
}

model intercompany_transactions {
  id                   Int       @id @default(autoincrement())
  organization_id      Int
  session_id           Int
  from_store_id        Int
  to_store_id          Int
  entry_id             Int
  counterpart_entry_id Int?
  account_id           Int
  amount               Decimal   @db.Decimal(12, 2)
  eliminated           Boolean   @default(false)
  eliminated_at        DateTime? @db.Timestamp(6)
  created_at           DateTime? @default(now()) @db.Timestamp(6)

  organization organizations          @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  session      consolidation_sessions @relation(fields: [session_id], references: [id], onDelete: Cascade)
  from_store   stores                 @relation("ic_from_store", fields: [from_store_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  to_store     stores                 @relation("ic_to_store", fields: [to_store_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  entry        accounting_entries     @relation("ic_entry", fields: [entry_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  counterpart  accounting_entries?    @relation("ic_counterpart", fields: [counterpart_entry_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  account      chart_of_accounts      @relation(fields: [account_id], references: [id], onDelete: Restrict, onUpdate: NoAction)

  @@index([session_id])
  @@index([organization_id, from_store_id, to_store_id])
}

model consolidation_adjustments {
  id                 Int                                @id @default(autoincrement())
  session_id         Int
  account_id         Int
  type               consolidation_adjustment_type_enum
  debit_amount       Decimal                            @default(0) @db.Decimal(12, 2)
  credit_amount      Decimal                            @default(0) @db.Decimal(12, 2)
  description        String                             @db.VarChar(500)
  store_id           Int?
  created_by_user_id Int?
  created_at         DateTime?                          @default(now()) @db.Timestamp(6)

  session    consolidation_sessions @relation(fields: [session_id], references: [id], onDelete: Cascade)
  account    chart_of_accounts      @relation(fields: [account_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  store      stores?                @relation(fields: [store_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  created_by users?                 @relation("consolidation_adj_created_by", fields: [created_by_user_id], references: [id], onDelete: Restrict, onUpdate: NoAction)

  @@index([session_id])
}

// ===== PAYROLL SETTLEMENTS =====

model payroll_settlements {
  id                 Int                     @id @default(autoincrement())
  organization_id    Int
  store_id           Int?
  employee_id        Int
  settlement_number  String                  @db.VarChar(50)
  status             settlement_status_enum  @default(draft)
  termination_date   DateTime                @db.Timestamp(6)
  termination_reason termination_reason_enum
  hire_date          DateTime                @db.Timestamp(6)
  days_worked        Int
  base_salary        Decimal                 @db.Decimal(12, 2)
  contract_type      contract_type_enum

  // Prestaciones sociales
  severance          Decimal @default(0) @db.Decimal(12, 2)
  severance_interest Decimal @default(0) @db.Decimal(12, 2)
  bonus              Decimal @default(0) @db.Decimal(12, 2)
  vacation           Decimal @default(0) @db.Decimal(12, 2)
  pending_salary     Decimal @default(0) @db.Decimal(12, 2)
  indemnification    Decimal @default(0) @db.Decimal(12, 2)

  // Deducciones
  health_deduction  Decimal @default(0) @db.Decimal(12, 2)
  pension_deduction Decimal @default(0) @db.Decimal(12, 2)
  other_deductions  Decimal @default(0) @db.Decimal(12, 2)
  total_deductions  Decimal @default(0) @db.Decimal(12, 2)

  // Totales
  gross_settlement Decimal @default(0) @db.Decimal(12, 2)
  net_settlement   Decimal @default(0) @db.Decimal(12, 2)

  // Detalle y documentacion
  calculation_detail  Json?
  document_url        String?   @db.Text
  accounting_entry_id Int?
  approved_by_user_id Int?
  approved_at         DateTime? @db.Timestamp(6)
  created_by_user_id  Int?
  notes               String?   @db.Text
  created_at          DateTime? @default(now()) @db.Timestamp(6)
  updated_at          DateTime? @default(now()) @db.Timestamp(6)

  organization     organizations       @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  store            stores?             @relation(fields: [store_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  employee         employees           @relation(fields: [employee_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  accounting_entry accounting_entries? @relation(fields: [accounting_entry_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  approved_by_user users?              @relation("settlements_approved_by", fields: [approved_by_user_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  created_by_user  users?              @relation("settlements_created_by", fields: [created_by_user_id], references: [id], onDelete: Restrict, onUpdate: NoAction)

  @@unique([organization_id, settlement_number])
  @@index([organization_id, status])
  @@index([employee_id])
  @@index([store_id])
}

// ===== EMPLOYEE ADVANCES =====

model employee_advances {
  id                  Int                          @id @default(autoincrement())
  organization_id     Int
  employee_id         Int
  advance_number      String                       @db.VarChar(50)
  amount_requested    Decimal                      @db.Decimal(12, 2)
  amount_approved     Decimal                      @default(0) @db.Decimal(12, 2)
  amount_paid         Decimal                      @default(0) @db.Decimal(12, 2)
  amount_pending      Decimal                      @default(0) @db.Decimal(12, 2)
  installments        Int                          @default(1)
  installment_value   Decimal                      @default(0) @db.Decimal(12, 2)
  frequency           payroll_frequency_enum       @default(monthly)
  status              employee_advance_status_enum @default(pending)
  advance_date        DateTime                     @db.Timestamp(6)
  reason              String?                      @db.VarChar(500)
  approved_by_user_id Int?
  approved_at         DateTime?                    @db.Timestamp(6)
  completed_at        DateTime?                    @db.Timestamp(6)
  notes               String?                      @db.VarChar(500)
  created_at          DateTime?                    @default(now()) @db.Timestamp(6)
  updated_at          DateTime?                    @default(now()) @db.Timestamp(6)

  organization         organizations                   @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  employee             employees                       @relation(fields: [employee_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  approved_by_user     users?                          @relation("advance_approved_by", fields: [approved_by_user_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  advance_payments     employee_advance_payments[]
  advance_installments employee_advance_installments[]

  @@unique([organization_id, advance_number])
  @@index([organization_id, status])
  @@index([employee_id, status])
