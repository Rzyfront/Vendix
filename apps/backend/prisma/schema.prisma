  balance_after  Decimal                       @db.Decimal(12, 2)
  reference_type String?                       @db.VarChar(50)
  reference_id   Int?
  description    String?                       @db.VarChar(500)
  metadata       Json?
  created_by     Int?
  created_at     DateTime                      @default(now()) @db.Timestamp(6)

  wallet wallets @relation(fields: [wallet_id], references: [id])

  @@index([wallet_id, created_at])
  @@index([reference_type, reference_id])
}

// ──── Accounts Payable (CxP) ────────────────

model accounts_payable {
  id              Int      @id @default(autoincrement())
  organization_id Int
  store_id        Int?
  supplier_id     Int
  source_type     String   @db.VarChar(50)
  source_id       Int?
  document_number String?  @db.VarChar(100)
  original_amount Decimal  @db.Decimal(12, 2)
  paid_amount     Decimal  @default(0.00) @db.Decimal(12, 2)
  balance         Decimal  @db.Decimal(12, 2)
  currency        String   @default("COP") @db.VarChar(10)
  issue_date      DateTime @db.Date
  due_date        DateTime @db.Date
  status          String   @default("open") @db.VarChar(20)
  days_overdue    Int      @default(0)
  priority        String   @default("normal") @db.VarChar(20)
  notes           String?  @db.Text
  created_at      DateTime @default(now()) @db.Timestamp(6)
  updated_at      DateTime @default(now()) @db.Timestamp(6)

  organizations        organizations          @relation("org_accounts_payable", fields: [organization_id], references: [id])
  supplier             suppliers              @relation("supplier_accounts_payable", fields: [supplier_id], references: [id])
  ap_payments          ap_payments[]
  ap_payment_schedules ap_payment_schedules[]

  @@index([organization_id, supplier_id])
  @@index([due_date, status])
}

model ap_payments {
  id                  Int      @id @default(autoincrement())
  accounts_payable_id Int
  amount              Decimal  @db.Decimal(12, 2)
  payment_date        DateTime @db.Timestamp(6)
  payment_method      String   @db.VarChar(50)
  reference           String?  @db.VarChar(255)
  bank_export_ref     String?  @db.VarChar(100)
  notes               String?  @db.Text
  created_by          Int?
  created_at          DateTime @default(now()) @db.Timestamp(6)

  accounts_payable accounts_payable @relation(fields: [accounts_payable_id], references: [id])

  @@index([accounts_payable_id])
}

model ap_payment_schedules {
  id                  Int       @id @default(autoincrement())
  accounts_payable_id Int
  scheduled_date      DateTime  @db.Date
  amount              Decimal   @db.Decimal(12, 2)
  status              String    @default("scheduled") @db.VarChar(20)
  processed_at        DateTime? @db.Timestamp(6)
  created_at          DateTime  @default(now()) @db.Timestamp(6)

  accounts_payable accounts_payable @relation(fields: [accounts_payable_id], references: [id])

  @@index([scheduled_date, status])
}

// ──── Comisiones ────────────────────────────

model commission_rules {
  id              Int       @id @default(autoincrement())
  store_id        Int
  name            String    @db.VarChar(100)
  description     String?   @db.Text
  rule_type       String    @db.VarChar(30)
  conditions      Json
  commission_type String    @db.VarChar(20)
  value           Decimal?  @db.Decimal(12, 4)
  tiers           Json?
  is_active       Boolean   @default(true)
  priority        Int       @default(0)
  valid_from      DateTime? @db.Date
  valid_to        DateTime? @db.Date
  created_at      DateTime  @default(now()) @db.Timestamp(6)
  updated_at      DateTime  @default(now()) @db.Timestamp(6)

  stores                  stores                    @relation("store_commission_rules", fields: [store_id], references: [id])
  commission_calculations commission_calculations[]

  @@index([store_id, is_active])
}

model commission_calculations {
  id                 Int      @id @default(autoincrement())
  store_id           Int
  commission_rule_id Int
  source_type        String   @db.VarChar(50)
  source_id          Int
  base_amount        Decimal  @db.Decimal(12, 2)
  commission_amount  Decimal  @db.Decimal(12, 2)
  calculation_detail Json?
  created_at         DateTime @default(now()) @db.Timestamp(6)

  stores          stores           @relation("store_commission_calcs", fields: [store_id], references: [id])
  commission_rule commission_rules @relation(fields: [commission_rule_id], references: [id])

  @@index([store_id, created_at])
  @@index([source_type, source_id])
}

model payment_links {
  id               Int                      @id @default(autoincrement())
  store_id         Int
  wompi_link_id    String                   @unique @db.VarChar(20)
  name             String                   @db.VarChar(255)
  description      String                   @db.Text
  amount_in_cents  Int?
  currency         String                   @default("COP") @db.VarChar(10)
  single_use       Boolean                  @default(true)
  collect_shipping Boolean                  @default(false)
  checkout_url     String                   @db.Text
  status           payment_link_status_enum @default(active)
  expires_at       DateTime?                @db.Timestamp(6)
  redirect_url     String?                  @db.Text
  image_url        String?                  @db.Text
  sku              String?                  @db.VarChar(36)
  order_id         Int?
  wompi_response   Json?
  transaction_id   String?                  @db.VarChar(255)
  paid_at          DateTime?                @db.Timestamp(6)
  created_by       Int?
  created_at       DateTime                 @default(now()) @db.Timestamp(6)
  updated_at       DateTime                 @default(now()) @db.Timestamp(6)

  stores stores  @relation(fields: [store_id], references: [id], onDelete: Cascade)
  orders orders? @relation(fields: [order_id], references: [id], onDelete: SetNull)

  @@index([store_id, status])
  @@index([store_id, created_at])
  @@index([wompi_link_id])
}

// ──── Customer Queue ───────────────────────────

model customer_queue {
  id              Int                        @id @default(autoincrement())
  store_id        Int
  token           String                     @unique @db.VarChar(64)
  first_name      String                     @db.VarChar(100)
  last_name       String                     @db.VarChar(100)
  document_type   String                     @db.VarChar(50)
  document_number String                     @db.VarChar(50)
  email           String?                    @db.VarChar(255)
  phone           String?                    @db.VarChar(50)
  status          customer_queue_status_enum @default(waiting)
  position        Int
  selected_by     Int?
  consumed_at     DateTime?                  @db.Timestamp(6)
  order_id        Int?
  customer_id     Int?
  expires_at      DateTime                   @db.Timestamp(6)
  created_at      DateTime                   @default(now()) @db.Timestamp(6)
  updated_at      DateTime                   @default(now()) @db.Timestamp(6)

  store stores @relation(fields: [store_id], references: [id])

  @@index([store_id, status])
  @@index([store_id, document_number])
  @@index([expires_at])
}

model invoice_data_requests {
  id              Int                              @id @default(autoincrement())
  store_id        Int
  order_id        Int
  invoice_id      Int?
  token           String                           @unique @db.VarChar(64)
  first_name      String?                          @db.VarChar(100)
  last_name       String?                          @db.VarChar(100)
  document_type   String?                          @db.VarChar(50)
  document_number String?                          @db.VarChar(50)
  email           String?                          @db.VarChar(255)
  phone           String?                          @db.VarChar(50)
  status          invoice_data_request_status_enum @default(pending)
  submitted_at    DateTime?                        @db.Timestamp(6)
  processed_at    DateTime?                        @db.Timestamp(6)
  new_invoice_id  Int?
  expires_at      DateTime                         @db.Timestamp(6)
  created_at      DateTime                         @default(now()) @db.Timestamp(6)
  updated_at      DateTime                         @default(now()) @db.Timestamp(6)

  store stores @relation(fields: [store_id], references: [id])
  order orders @relation(fields: [order_id], references: [id])

  @@index([store_id, status])
  @@index([order_id])
  @@index([expires_at])
}

// ============================================
// ENTITY METADATA SYSTEM (Dynamic Fields)
// ============================================

model entity_metadata_fields {
  id            Int                        @id @default(autoincrement())
  store_id      Int
  entity_type   entity_type_enum
  field_key     String                     @db.VarChar(100)
  field_type    field_type_enum
  label         String                     @db.VarChar(255)
  description   String?                    @db.Text
  is_required   Boolean                    @default(false)
  display_mode  metadata_display_mode_enum @default(detail)
  sort_order    Int                        @default(0)
  options       Json?
  default_value String?                    @db.Text
  is_active     Boolean                    @default(true)
  created_at    DateTime                   @default(now()) @db.Timestamp(6)
  updated_at    DateTime                   @default(now()) @db.Timestamp(6)

  store          stores                      @relation(fields: [store_id], references: [id])
  values         entity_metadata_values[]
  template_items data_collection_items[]

  @@unique([store_id, entity_type, field_key])
  @@index([store_id, entity_type, is_active])
}

model entity_metadata_values {
  id           Int              @id @default(autoincrement())
  store_id     Int
  field_id     Int
  entity_type  entity_type_enum
  entity_id    Int
  value_text   String?          @db.Text
  value_number Decimal?         @db.Decimal(12, 4)
  value_date   DateTime?        @db.Date
  value_bool   Boolean?
  value_json   Json?
  created_at   DateTime         @default(now()) @db.Timestamp(6)
  updated_at   DateTime         @default(now()) @db.Timestamp(6)

  store stores                 @relation(fields: [store_id], references: [id])
  field entity_metadata_fields @relation(fields: [field_id], references: [id], onDelete: Cascade)

  @@unique([field_id, entity_type, entity_id])
  @@index([store_id, entity_type, entity_id])
  @@index([field_id])
  @@index([field_id, value_number])
  @@index([field_id, value_date])
}

// ============================================
// DATA COLLECTION SYSTEM (Templates & Forms)
// ============================================

model data_collection_templates {
  id          Int                  @id @default(autoincrement())
  store_id    Int
  name        String               @db.VarChar(255)
  description String?              @db.Text
  icon        String?              @db.VarChar(100)
  status      template_status_enum @default(active)
  entity_type entity_type_enum     @default(booking)
  is_default  Boolean              @default(false)
  created_at  DateTime             @default(now()) @db.Timestamp(6)
  updated_at  DateTime             @default(now()) @db.Timestamp(6)

  store       stores                              @relation(fields: [store_id], references: [id])
  sections    data_collection_sections[]
  tabs      data_collection_tabs[]
  products    data_collection_template_products[]
  submissions data_collection_submissions[]
  consultation_products     products[]  @relation("product_consultation_template")
  preconsultation_products  products[]  @relation("product_preconsultation_template")

  @@index([store_id, status])
  @@index([store_id, entity_type])
}

model data_collection_tabs {
  id          Int      @id @default(autoincrement())
  template_id Int
  title       String   @db.VarChar(255)
  icon        String?  @db.VarChar(100)
  sort_order  Int      @default(0)
  created_at  DateTime @default(now()) @db.Timestamp(6)
  updated_at  DateTime @default(now()) @db.Timestamp(6)

  template data_collection_templates @relation(fields: [template_id], references: [id], onDelete: Cascade)
  sections data_collection_sections[]

  @@index([template_id, sort_order])
}

model data_collection_sections {
  id          Int      @id @default(autoincrement())
  template_id Int
  title       String   @db.VarChar(255)
  description String?  @db.Text
  sort_order  Int      @default(0)
  tab_id            Int?
  parent_section_id Int?
  icon              String?  @db.VarChar(100)
  created_at  DateTime @default(now()) @db.Timestamp(6)
  updated_at  DateTime @default(now()) @db.Timestamp(6)

  template data_collection_templates @relation(fields: [template_id], references: [id], onDelete: Cascade)
  items    data_collection_items[]
  tab            data_collection_tabs?      @relation(fields: [tab_id], references: [id], onDelete: SetNull)
  parent_section data_collection_sections?  @relation("section_nesting", fields: [parent_section_id], references: [id], onDelete: Cascade)
  child_sections data_collection_sections[] @relation("section_nesting")

  @@index([template_id, sort_order])
  @@index([tab_id, sort_order])
  @@index([parent_section_id, sort_order])
}

model data_collection_items {
  id                Int      @id @default(autoincrement())
  section_id        Int
  metadata_field_id Int
  sort_order        Int      @default(0)
  is_required        Boolean  @default(false)
  include_in_summary Boolean  @default(false)
  help_text          String?  @db.Text
  placeholder        String?  @db.VarChar(255)
  validation_rules   Json?
  width              String?  @db.VarChar(10)
  icon               String?  @db.VarChar(100)
  created_at         DateTime @default(now()) @db.Timestamp(6)

  section        data_collection_sections @relation(fields: [section_id], references: [id], onDelete: Cascade)
  metadata_field entity_metadata_fields   @relation(fields: [metadata_field_id], references: [id])

  @@unique([section_id, metadata_field_id])
  @@index([section_id, sort_order])
}

model data_collection_template_products {
  id          Int @id @default(autoincrement())
  template_id Int
  product_id  Int

  template data_collection_templates @relation(fields: [template_id], references: [id], onDelete: Cascade)
  product  products                  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([template_id, product_id])
  @@index([product_id])
}

model data_collection_submissions {
  id              Int                    @id @default(autoincrement())
  store_id        Int
  template_id     Int
  booking_id      Int?
  customer_id     Int?
  token           String                 @unique @db.VarChar(64)
  status          submission_status_enum @default(pending)
  current_step    Int                    @default(0)
  ai_prediagnosis String?                @db.Text
  ai_job_id       String?                @db.VarChar(100)
  submitted_at    DateTime?              @db.Timestamp(6)
  processed_at    DateTime?              @db.Timestamp(6)
  expires_at      DateTime               @db.Timestamp(6)
  created_at      DateTime               @default(now()) @db.Timestamp(6)
  updated_at      DateTime               @default(now()) @db.Timestamp(6)

  store     stores                      @relation(fields: [store_id], references: [id])
  template  data_collection_templates   @relation(fields: [template_id], references: [id])
  booking   bookings?                   @relation(fields: [booking_id], references: [id])
  customer  users?                      @relation("submission_customer", fields: [customer_id], references: [id])
  @@index([store_id, status])
  @@index([booking_id])
  @@index([customer_id])
  @@index([expires_at])
}

// ============================================
// CONSULTATION HISTORY (Snapshots & Notes)
// ============================================

model booking_metadata_snapshots {
  id          Int      @id @default(autoincrement())
  store_id    Int
  booking_id  Int      @unique
  customer_id Int
  snapshot    Json
  created_at  DateTime @default(now()) @db.Timestamp(6)

  store    stores   @relation(fields: [store_id], references: [id])
  booking  bookings @relation(fields: [booking_id], references: [id])
  customer users    @relation("metadata_snapshot_customer", fields: [customer_id], references: [id])

  @@index([customer_id, created_at])
  @@index([store_id, customer_id])
}

model customer_consultation_notes {
  id                 Int      @id @default(autoincrement())
  store_id           Int
  customer_id        Int
  booking_id         Int
  note_key           String   @db.VarChar(100)
  note_value         String   @db.Text
  include_in_summary Boolean  @default(false)
  created_by_id      Int?
  created_at         DateTime @default(now()) @db.Timestamp(6)
  updated_at         DateTime @default(now()) @db.Timestamp(6)

  store      stores   @relation(fields: [store_id], references: [id])
  customer   users    @relation("consultation_notes_customer", fields: [customer_id], references: [id])
  booking    bookings @relation(fields: [booking_id], references: [id])
  created_by users?   @relation("consultation_notes_created_by", fields: [created_by_id], references: [id])

  @@index([customer_id, store_id])
  @@index([booking_id])
  @@index([customer_id, include_in_summary])
}

// ============================================
// BOOKING CONFIRMATION & REMINDERS
// ============================================

model booking_confirmation_tokens {
  id         Int       @id @default(autoincrement())
  booking_id Int
  store_id   Int
  token      String    @unique @db.VarChar(64)
  action     String    @db.VarChar(20)
  expires_at DateTime  @db.Timestamp(6)
  used       Boolean   @default(false)
  used_at    DateTime? @db.Timestamp(6)
  created_at DateTime  @default(now()) @db.Timestamp(6)

  booking bookings @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  store   stores   @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([booking_id])
}

model booking_reminder_logs {
  id           Int      @id @default(autoincrement())
  booking_id   Int
  store_id     Int
  reminder_key String   @db.VarChar(30)
  channel      String   @db.VarChar(20)
  sent_at      DateTime @default(now()) @db.Timestamp(6)

  booking bookings @relation(fields: [booking_id], references: [id], onDelete: Cascade)

  @@unique([booking_id, reminder_key, channel])
  @@index([store_id, sent_at])
}

// ============================================
// EMAIL TEMPLATES
// ============================================

model email_templates {
  id         Int      @id @default(autoincrement())
  store_id   Int?
  event_type String   @db.VarChar(50)
  subject    String   @db.VarChar(255)
  body_html  String   @db.Text
  body_text  String?  @db.Text
  variables  Json?
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @default(now()) @db.Timestamp(6)

  store stores? @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@unique([store_id, event_type])
  @@index([event_type, is_active])
}

// ============================================
// MESSAGING CHANNELS (WhatsApp/SMS prep)
// ============================================

model messaging_channels {
  id           Int      @id @default(autoincrement())
  store_id     Int
  channel_type String   @db.VarChar(20)
  provider     String   @db.VarChar(30)
  config       Json
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now()) @db.Timestamp(6)
  updated_at   DateTime @default(now()) @db.Timestamp(6)

  store stores @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@unique([store_id, channel_type])
}
