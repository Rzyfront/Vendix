  expected_date        DateTime?              @db.Timestamp(6)
  completed_date       DateTime?              @db.Timestamp(6)
  notes                String?
  created_by_user_id   Int?
  approved_by_user_id  Int?
  created_at           DateTime?              @default(now()) @db.Timestamp(6)
  updated_at           DateTime?              @default(now()) @db.Timestamp(6)
  stock_transfer_items stock_transfer_items[]
  users                users?                 @relation("stock_transfers_approved_by", fields: [approved_by_user_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  users1               users?                 @relation("stock_transfers_created_by", fields: [created_by_user_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  from_location        inventory_locations    @relation("from_location", fields: [from_location_id], references: [id], onUpdate: NoAction)
  organizations        organizations          @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  to_location          inventory_locations    @relation("to_location", fields: [to_location_id], references: [id], onUpdate: NoAction)

