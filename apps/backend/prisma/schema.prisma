// ===== ACCOUNTING DOMAIN =====

model chart_of_accounts {
  id              Int                @id @default(autoincrement())
  organization_id Int
  code            String             @db.VarChar(20)
  name            String             @db.VarChar(255)
  account_type    account_type_enum
  nature          account_nature_enum
  parent_id       Int?
  level           Int                @default(1)
  is_active       Boolean            @default(true)
  accepts_entries Boolean            @default(false)
  created_at      DateTime?          @default(now()) @db.Timestamp(6)
  updated_at      DateTime?          @default(now()) @db.Timestamp(6)

  organization          organizations           @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  parent                chart_of_accounts?      @relation("chart_of_accounts_parent", fields: [parent_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  children              chart_of_accounts[]     @relation("chart_of_accounts_parent")
  accounting_entry_lines      accounting_entry_lines[]
  accounting_account_mappings accounting_account_mappings[]

  @@unique([organization_id, code])
  @@index([organization_id, parent_id])
  @@index([organization_id, account_type])
}

model accounting_account_mappings {
  id              Int       @id @default(autoincrement())
  organization_id Int
  store_id        Int?
  mapping_key     String    @db.VarChar(100)
  account_id      Int
  is_active       Boolean   @default(true)
  created_at      DateTime? @default(now()) @db.Timestamp(6)
  updated_at      DateTime? @default(now()) @db.Timestamp(6)

  organization organizations     @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  store        stores?            @relation(fields: [store_id], references: [id], onDelete: Cascade)
  account      chart_of_accounts  @relation(fields: [account_id], references: [id], onDelete: Restrict)

  @@unique([organization_id, store_id, mapping_key])
  @@index([organization_id, store_id])
}

model fiscal_periods {
  id               Int                       @id @default(autoincrement())
  organization_id  Int
  name             String                    @db.VarChar(50)
  start_date       DateTime                  @db.Timestamp(6)
  end_date         DateTime                  @db.Timestamp(6)
  status           fiscal_period_status_enum  @default(open)
  closed_by_user_id Int?
  closed_at        DateTime?                 @db.Timestamp(6)
  created_at       DateTime?                 @default(now()) @db.Timestamp(6)
  updated_at       DateTime?                 @default(now()) @db.Timestamp(6)

  organization       organizations        @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  closed_by_user     users?               @relation("fiscal_periods_closed_by", fields: [closed_by_user_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  accounting_entries accounting_entries[]

  @@unique([organization_id, name])
}

model accounting_entries {
  id                 Int                           @id @default(autoincrement())
  organization_id    Int
  store_id           Int?
  entry_number       String                        @db.VarChar(50)
  entry_type         accounting_entry_type_enum     @default(manual)
  status             accounting_entry_status_enum   @default(draft)
  fiscal_period_id   Int
  entry_date         DateTime                      @db.Timestamp(6)
  description        String?                       @db.VarChar(500)
  source_type        String?                       @db.VarChar(50)
  source_id          Int?
  total_debit        Decimal                       @default(0) @db.Decimal(12, 2)
  total_credit       Decimal                       @default(0) @db.Decimal(12, 2)
  created_by_user_id Int?
  posted_by_user_id  Int?
  posted_at          DateTime?                     @db.Timestamp(6)
  created_at         DateTime?                     @default(now()) @db.Timestamp(6)
  updated_at         DateTime?                     @default(now()) @db.Timestamp(6)

  organization           organizations           @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  store                  stores?                 @relation(fields: [store_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  fiscal_period          fiscal_periods          @relation(fields: [fiscal_period_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  created_by_user        users?                  @relation("accounting_entries_created_by", fields: [created_by_user_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  posted_by_user         users?                  @relation("accounting_entries_posted_by", fields: [posted_by_user_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  accounting_entry_lines accounting_entry_lines[]
  invoices               invoices[]
  payroll_runs           payroll_runs[]

  @@unique([organization_id, entry_number])
  @@index([organization_id, entry_date])
  @@index([organization_id, fiscal_period_id])
  @@index([source_type, source_id])
}

model accounting_entry_lines {
  id            Int       @id @default(autoincrement())
  entry_id      Int
  account_id    Int
  description   String?   @db.VarChar(500)
  debit_amount  Decimal   @default(0) @db.Decimal(12, 2)
  credit_amount Decimal   @default(0) @db.Decimal(12, 2)
  created_at    DateTime? @default(now()) @db.Timestamp(6)

  entry   accounting_entries @relation(fields: [entry_id], references: [id], onDelete: Cascade)
  account chart_of_accounts  @relation(fields: [account_id], references: [id], onDelete: Restrict, onUpdate: NoAction)

  @@index([entry_id])
  @@index([account_id])
}

// ===== PAYROLL DOMAIN =====

model employees {
