  @@unique([organization_id, invoice_type, invoice_number])
  @@index([store_id, status])
  @@index([organization_id, issue_date])
  @@index([customer_id])
}

model invoice_items {
  id                 Int               @id @default(autoincrement())
  invoice_id         Int
  product_id         Int?
  product_variant_id Int?
  description        String            @db.VarChar(500)
  quantity           Decimal           @db.Decimal(12, 4)
  unit_price         Decimal           @db.Decimal(12, 2)
  discount_amount    Decimal           @default(0) @db.Decimal(12, 2)
  tax_amount         Decimal           @default(0) @db.Decimal(12, 2)
  total_amount       Decimal           @db.Decimal(12, 2)
  created_at         DateTime?         @default(now()) @db.Timestamp(6)

  invoice          invoices           @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  product          products?          @relation(fields: [product_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  product_variant  product_variants?  @relation(fields: [product_variant_id], references: [id], onDelete: Restrict, onUpdate: NoAction)

  @@index([invoice_id])
}

model invoice_taxes {
  id             Int        @id @default(autoincrement())
  invoice_id     Int
  tax_rate_id    Int?
  tax_name       String     @db.VarChar(100)
  tax_rate       Decimal    @db.Decimal(5, 2)
  taxable_amount Decimal    @db.Decimal(12, 2)
  tax_amount     Decimal    @db.Decimal(12, 2)

  invoice   invoices    @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  tax_rates tax_rates?  @relation(fields: [tax_rate_id], references: [id], onDelete: Restrict, onUpdate: NoAction)

  @@index([invoice_id])
