model legal_documents {
  id             Int                      @id @default(autoincrement())
  document_type  legal_document_type_enum
  title          String                   @db.VarChar(255)
  version        String                   @db.VarChar(20)
  content        String                   @db.Text
  description    String?                  @db.Text
  effective_date DateTime                 @db.Timestamp(6)
  expiry_date    DateTime?                @db.Timestamp(6)
  is_active      Boolean                  @default(true)
  is_system      Boolean                  @default(false)
  document_url   String?                  @db.Text

  // Scope del documento
  organization_id Int?
  store_id        Int?

  // Auditoría de cambios
  created_by_user_id Int?
  created_at         DateTime? @default(now()) @db.Timestamp(6)
  updated_at         DateTime? @default(now()) @db.Timestamp(6)

  // Relaciones
  document_acceptances document_acceptances[]

  @@unique([version, store_id, organization_id, document_type])
  @@index([document_type, is_active])
  @@index([effective_date])
  @@index([organization_id])
  @@index([store_id])
  @@index([document_type, organization_id, is_active])
  @@index([document_type, store_id, is_active])
}

model document_acceptances {
  id                 Int      @id @default(autoincrement())
  user_id            Int
  document_id        Int
  acceptance_version String   @db.VarChar(20)
  accepted_at        DateTime @default(now()) @db.Timestamp(6)

  // Datos legales de la aceptación
  accepted_by_user_id Int?
  ip_address          String? @db.VarChar(45)
  user_agent          String?
  metadata            Json?

  // Relaciones
  document legal_documents @relation(fields: [document_id], references: [id], onDelete: Cascade)
  user     users           @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, document_id, acceptance_version])
  @@index([user_id])
  @@index([document_id, accepted_at])
  @@index([accepted_at])
}

