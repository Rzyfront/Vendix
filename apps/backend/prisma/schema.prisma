}

model purchase_order_reception_items {
  id                     Int       @id @default(autoincrement())
  reception_id           Int
  purchase_order_item_id Int
  quantity_received      Int

  reception              purchase_order_receptions @relation(fields: [reception_id], references: [id], onDelete: Cascade)
  purchase_order_item    purchase_order_items      @relation(fields: [purchase_order_item_id], references: [id], onDelete: Cascade)

  @@index([reception_id])
  @@index([purchase_order_item_id])
}

model sales_orders {
  id                  Int                     @id @default(autoincrement())
