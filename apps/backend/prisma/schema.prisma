  @@unique([store_id, customer_id])
  @@index([store_id])
}

model wallet_transactions {
  id             Int                           @id @default(autoincrement())
  wallet_id      Int
  type           wallet_transaction_type_enum
  state          wallet_transaction_state_enum @default(pending)
  amount         Decimal                       @db.Decimal(12, 2)
