// ===== PROMOTIONS =====

model promotions {
  id                  Int                  @id @default(autoincrement())
  store_id            Int
  name                String               @db.VarChar(255)
  description         String?
  code                String?              @db.VarChar(50)
  type                promotion_type_enum
  value               Decimal              @db.Decimal(12, 2)
  scope               promotion_scope_enum @default(order)
  min_purchase_amount Decimal?             @db.Decimal(12, 2)
  max_discount_amount Decimal?             @db.Decimal(12, 2)
  usage_limit         Int?
  usage_count         Int                  @default(0)
  per_customer_limit  Int?
  start_date          DateTime             @db.Timestamp(6)
  end_date            DateTime?            @db.Timestamp(6)
  state               promotion_state_enum @default(draft)
  is_auto_apply       Boolean              @default(false)
  priority            Int                  @default(0)
  created_at          DateTime?            @default(now()) @db.Timestamp(6)
  updated_at          DateTime?            @default(now()) @db.Timestamp(6)

  stores               stores                 @relation(fields: [store_id], references: [id], onUpdate: NoAction)
  promotion_products   promotion_products[]
  promotion_categories promotion_categories[]
  order_promotions     order_promotions[]

  @@unique([store_id, code])
  @@index([store_id, state])
  @@index([store_id, start_date, end_date])
}

model promotion_products {
  id           Int        @id @default(autoincrement())
  promotion_id Int
  product_id   Int
  promotions   promotions @relation(fields: [promotion_id], references: [id], onDelete: Cascade)
  products     products   @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([promotion_id, product_id])
}

model promotion_categories {
  id           Int        @id @default(autoincrement())
  promotion_id Int
  category_id  Int
  promotions   promotions @relation(fields: [promotion_id], references: [id], onDelete: Cascade)
  categories   categories @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@unique([promotion_id, category_id])
}

model order_promotions {
  id              Int        @id @default(autoincrement())
  order_id        Int
  promotion_id    Int
  customer_id     Int?
  discount_amount Decimal    @db.Decimal(12, 2)
  created_at      DateTime?  @default(now()) @db.Timestamp(6)
  orders          orders     @relation(fields: [order_id], references: [id], onDelete: Cascade)
  promotions      promotions @relation(fields: [promotion_id], references: [id], onDelete: Cascade)
  customers       users?     @relation("order_promotions_customer", fields: [customer_id], references: [id], onDelete: SetNull)

  @@unique([order_id, promotion_id])
  @@index([promotion_id, customer_id])
}

