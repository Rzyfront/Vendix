  currency            String?                  @db.VarChar(10)
  exchange_rate       Decimal?                 @db.Decimal(12, 6)
  resolution_id       Int?
  cufe                String?                  @db.VarChar(255)
  qr_code             String?
  xml_document        String?
  pdf_url             String?
  send_status         document_send_status_enum @default(not_applicable)
  provider_response   Json?
  sent_at             DateTime?                @db.Timestamp(6)
  accepted_at         DateTime?                @db.Timestamp(6)
  issue_date          DateTime                 @db.Timestamp(6)
  due_date            DateTime?                @db.Timestamp(6)
  payment_date        DateTime?                @db.Timestamp(6)
  accounting_entry_id Int?
  created_by_user_id  Int?
  notes               String?
  created_at          DateTime?                @default(now()) @db.Timestamp(6)
  updated_at          DateTime?                @default(now()) @db.Timestamp(6)

  organization       organizations            @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  store              stores                   @relation(fields: [store_id], references: [id], onDelete: Cascade)
  customer           users?                   @relation("invoices_customer", fields: [customer_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  supplier           suppliers?               @relation(fields: [supplier_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  order              orders?                  @relation(fields: [order_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  sales_order        sales_orders?            @relation(fields: [sales_order_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  related_invoice    invoices?                @relation("invoice_credit_debit_notes", fields: [related_invoice_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  credit_debit_notes invoices[]               @relation("invoice_credit_debit_notes")
  resolution         invoice_resolutions?     @relation(fields: [resolution_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  accounting_entry   accounting_entries?      @relation(fields: [accounting_entry_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  created_by_user    users?                   @relation("invoices_created_by", fields: [created_by_user_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
