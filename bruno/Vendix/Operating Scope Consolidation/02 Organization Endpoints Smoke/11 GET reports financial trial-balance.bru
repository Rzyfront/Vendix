get {
  url: http://{{url}}/organization/reports/financial/trial-balance
  body: none
  auth: bearer
}

auth:bearer {
  token: {{orgAdminToken}}
}

tests {
  test("200", function () {
    expect(res.status).to.equal(200);
  });
}
