meta {
  name: 14 POST mark-step-completed initial_inventory
  type: http
  seq: 14
}

post {
  url: http://{{url}}/store/settings/fiscal-status/accounting/mark-step-completed
  body: json
  auth: bearer
}

auth:bearer {
  token: {{storeAdminToken}}
}

body:json {
  {
    "step": "initial_inventory",
    "ref": {
      "scope": "STORE"
    }
  }
}

tests {
  test("records initial_inventory step in accounting completed_steps", function () {
    expect(res.status).to.be.oneOf([200, 201]);
    const body = res.body.data || res.body;
    const completed = body.fiscal_status.accounting.wizard.completed_steps || [];
    const steps = completed.map(s => s.step || s);
    expect(steps).to.include('initial_inventory');
  });
}
