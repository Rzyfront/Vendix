meta {
  name: Checkout - Con IDs validos
  type: http
  seq: 2
}

post {
  url: {{url}}/ecommerce/checkout
  body: json
  auth: inherit
}

body:json {
  {
    "payment_method_id": 1,
    "items": [
      {
        "product_id": 1,
        "quantity": 2
      }
    ]
  }
}

tests {
  test("No debe ser 400 por validacion de IDs", function() {
    expect(res.status).to.not.equal(400);
  });
}
