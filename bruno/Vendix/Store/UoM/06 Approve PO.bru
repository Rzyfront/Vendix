meta {
  name: 06 Approve PO
  type: http
  seq: 7
}

patch {
  url: {{baseUrl}}/store/orders/purchase-orders/{{uom_po_id}}/approve
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{uomToken}}
}

tests {
  test("PO aprobada", function() {
    expect(res.status).to.equal(200);
    expect(res.body.success).to.be.true;
    expect(res.body.data.status).to.equal('approved');
  });
}
