meta {
  name: Get Current Access
  type: http
  seq: 1
}

get {
  url: http://{{url}}/store/subscriptions/current/access
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

tests {
  test("Get current access successful", function() {
    expect(res.status).to.equal(200);
    expect(res.body.success).to.be.true;
    expect(res.body.data).to.have.property('allowed');
    expect(res.body.data).to.have.property('mode');
  });
}
