meta {
  name: Cancel Subscription
  type: http
  seq: 6
}

post {
  url: {{url}}/store/subscriptions/cancel
  body: json
  auth: inherit
}

body:json {
  {
    "reason": "user_initiated_cancel"
  }
}

tests {
  test("Cancel successful", function() {
    expect(res.status).to.equal(200);
    expect(res.body.success).to.be.true;
  });
}
